---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";

const navLinks = [
  { href: "#platform", label: "Platform" },
  { href: "#regulators", label: "Regulators" },
  { href: "#architecture", label: "Architecture" },
  { href: "#faq", label: "FAQ" },
];
const navCta = { href: "#demo", label: "Request a demo →" };
---

<Layout variant="insurance">
  <Nav variant="insurance" links={navLinks} cta={navCta} />

  <header class="hero">
    <div class="wrap">
      <span class="eyebrow">For carriers, reinsurers, and Lloyd's syndicates</span>
      <h1>AI governance, <em>built for insurance.</em></h1>
      <p class="lead">
        One platform — observability, evidence, and synthetic testing — for
        every model running in your underwriting, distribution, and claims
        stack. Aligned to the NAIC Model Bulletin, NY DFS Circular Letter
        2024-7, Colorado SB21-169, the EU AI Act, DORA, and IDD.
      </p>
      <div class="cta-row">
        <a href="#demo" class="btn btn-primary">Request a demo →</a>
        <a href="#sample" class="btn btn-ghost">See a sample audit bundle</a>
      </div>
      <div class="hero-meta">
        <span><strong>Deployed</strong> single-tenant, VPC, or air-gapped</span>
        <span><strong>EU + US</strong> data residency, customer-pinned</span>
        <span><strong>Model-agnostic</strong> — OpenAI, Anthropic, Mistral, fine-tuned, self-hosted</span>
      </div>
    </div>
  </header>

  <!-- TRUST STRIP -->
  <section class="trust" style="padding: 36px 0; border-bottom: 1px solid var(--line);">
    <div class="wrap">
      <div class="trust-label">Built for the AI, compliance, and actuarial teams at</div>
      <div class="trust-items">
        <span class="chip">US P&amp;C carriers</span>
        <span class="chip">Lloyd's syndicates</span>
        <span class="chip">EU specialty insurers</span>
        <span class="chip">European reinsurers</span>
        <span class="chip">Bermuda &amp; Cayman captives</span>
        <span class="chip">Tier-1 brokers &amp; MGAs</span>
      </div>
    </div>
  </section>

  <!-- THE PROBLEM -->
  <section id="problem">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">The problem</div>
        <h2>Three regulators. Five LLMs. One audit window.</h2>
        <p class="lead">
          Carriers now run AI in claims triage, bordereaux summarization, FNOL
          intake, underwriting copilots, and customer storefronts. Each model
          drifts independently. Each jurisdiction asks the same question
          slightly differently. None of the existing observability stacks were
          built to answer a regulator.
        </p>
      </div>
    </div>
  </section>

  <!-- PLATFORM -->
  <section id="platform" style="padding-top: 24px;">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">The platform</div>
        <h2>Three modules. One ledger.</h2>
      </div>

      <div class="feature-grid">
        <div class="feature-card">
          <div class="feature-num">01</div>
          <h3>Observability</h3>
          <p>Every prompt, every answer, every tool call from every model — captured to a structured trace. Cross-model funnel: see which surface answered which question, where the carrier shows up in AI-generated discovery, and which queries dropped a competitor's name. PII-safe in hash-only mode.</p>
        </div>
        <div class="feature-card">
          <div class="feature-num">02</div>
          <h3>Evidence</h3>
          <p>Policy-as-code on every inference. Immutable session ledger with cryptographic chain-of-custody. One-click bundles formatted for the requesting body — NAIC data call, NY DFS Circular Letter annex, EIOPA supervisory data, DORA incident form. Audit response in an afternoon, not weeks.</p>
        </div>
        <div class="feature-card">
          <div class="feature-num">03</div>
          <h3>Synthetic testing</h3>
          <p>Continuous behavioral probes against your live AI surface. 400+ insurance personas — denied claimants, underinsured renters, BOP shoppers, life-at-renewal. Regression alerts catch model drift between vendor updates. Bias regressions flagged against state-by-state thresholds.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- QUOTE 1 -->
  <section style="padding: 64px 0;">
    <div class="wrap">
      <blockquote class="pullquote">
        <p>"We were running six LLM-backed workflows across claims triage and bordereaux summarization. Three regulators asking variations of the same question. Phidea cut our audit response time from three weeks to an afternoon — and we stopped guessing about model drift in between."</p>
        <footer>— Chief AI Officer, top-5 European reinsurer</footer>
      </blockquote>
    </div>
  </section>

  <!-- REGULATORY MAPPING -->
  <section id="regulators">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">Regulatory coverage</div>
        <h2>Pre-mapped to the regulators you actually answer to.</h2>
        <p class="lead">
          Every policy pack ships with the controls, evidence schema, and
          export format the regulator expects. Carrier teams extend packs with
          internal controls without touching the rule engine.
        </p>
      </div>

      <table class="reg-table">
        <thead>
          <tr><th>Jurisdiction</th><th>Framework</th><th>What Phidea ships</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>US — NAIC</strong></td>
            <td>Model Bulletin on the Use of AI</td>
            <td>Schedule F mapping, third-party AI register, bias-testing protocol per LOB</td>
          </tr>
          <tr>
            <td><strong>US — Colorado</strong></td>
            <td>SB21-169 (life)</td>
            <td>Quantitative testing methodology + protected-class proxy detection</td>
          </tr>
          <tr>
            <td><strong>US — New York</strong></td>
            <td>DFS Circular Letter 2024-7</td>
            <td>Third-party AI vendor due diligence pack + ECDIS controls</td>
          </tr>
          <tr>
            <td><strong>EU</strong></td>
            <td>AI Act (Annex III high-risk)</td>
            <td>Risk management system, post-market monitoring, technical documentation export</td>
          </tr>
          <tr>
            <td><strong>EU</strong></td>
            <td>DORA</td>
            <td>ICT third-party register, incident classification, resilience testing logs</td>
          </tr>
          <tr>
            <td><strong>EU/UK</strong></td>
            <td>IDD / FCA Consumer Duty</td>
            <td>Advice-boundary classifier, distribution-chain audit trail</td>
          </tr>
          <tr>
            <td><strong>EU</strong></td>
            <td>EIOPA AI Governance Principles</td>
            <td>Proportionality assessment + governance evidence export</td>
          </tr>
          <tr>
            <td><strong>Global</strong></td>
            <td>ISO/IEC 42001 (AI management)</td>
            <td>Control mapping + continuous-improvement evidence stream</td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- QUOTE 2 -->
  <section style="padding: 64px 0;">
    <div class="wrap">
      <blockquote class="pullquote">
        <p>"Moving our claims-triage LLM behind Phidea's gateway meant our compliance team could say 'yes' to the underwriting team for the first time in two years. The bottleneck moved from our compliance review back to where it belongs — actuarial sign-off."</p>
        <footer>— Chief Compliance Officer, US personal lines carrier</footer>
      </blockquote>
    </div>
  </section>

  <!-- ARCHITECTURE -->
  <section id="architecture">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">How it works</div>
        <h2>Four steps. No re-platforming.</h2>
      </div>

      <div class="arch-grid">
        <div class="arch-step">
          <div class="arch-num">1</div>
          <h3>Route through Phidea's gateway or MCP server.</h3>
          <p>OpenAI-compatible proxy, native MCP, or SDK. Drop-in for any model — OpenAI, Anthropic, Google, Cohere, Mistral, Azure, Bedrock, self-hosted, fine-tuned. Average integration: half a day.</p>
        </div>
        <div class="arch-step">
          <div class="arch-num">2</div>
          <h3>Attach a policy pack.</h3>
          <p>Sample packs ship for NAIC, NY DFS, Colorado SB21-169, EU AI Act, DORA, IDD, EIOPA. Carrier-specific overlays added in YAML — version-controlled, code-reviewed, replayable against historical traffic.</p>
        </div>
        <div class="arch-step">
          <div class="arch-num">3</div>
          <h3>Every inference goes to the session ledger.</h3>
          <p>Append-only, cryptographically signed, customer-pinned residency. Captures prompt, response, tool calls, policy decisions, model + version, and a full trace context — the artifact a regulator actually needs.</p>
        </div>
        <div class="arch-step">
          <div class="arch-num">4</div>
          <h3>Export the bundle the regulator expects.</h3>
          <p>One click. Format-mapped to the requesting body. PDF + machine-readable annex + signed manifest. Exports are themselves logged, so you have evidence of who asked, what you sent, and when.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- QUOTE 3 -->
  <section style="padding: 64px 0;">
    <div class="wrap">
      <blockquote class="pullquote">
        <p>"The synthetic-buyers module caught a drift in our underwriting chatbot the morning after a vendor model update — before any customer noticed and before our QA team's weekly sweep. That single catch paid for the platform."</p>
        <footer>— Head of Digital, London specialty MGA</footer>
      </blockquote>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">FAQ</div>
        <h2>Direct answers, in carrier vocabulary.</h2>
      </div>

      <details>
        <summary>How long does a deployment take?</summary>
        <p>Half a day to instrument a first model in read-only observability mode. Two to four weeks for the full evidence pipeline with one carrier-specific policy overlay. Multi-LOB rollouts run six to twelve weeks, gated by carrier data readiness rather than Phidea integration.</p>
      </details>
      <details>
        <summary>Where does the data live? Does Phidea see PII?</summary>
        <p>Customer-pinned residency: EU (Frankfurt, Paris, Dublin) or US (Ashburn, Oregon). Single-tenant on request. The observability layer can run in hash-only mode — raw prompts and answers never leave your boundary, only structural metadata and policy decisions. Air-gapped deployments use the same code path; nothing phones home.</p>
      </details>
      <details>
        <summary>How does Phidea integrate with existing AI stacks?</summary>
        <p>Three options: (a) OpenAI-compatible gateway in front of any model — zero application code changes; (b) native MCP server for Claude Desktop, OpenAI Agents, LangGraph, Cursor; (c) SDK for engineering teams that want explicit control. Most carriers start with (a) and add (b) when they ship agents.</p>
      </details>
      <details>
        <summary>What's the security and certification posture?</summary>
        <p>Security program designed against ISO/IEC 27001, SOC 2 Type II, and HIPAA control baselines. SIG questionnaire, pen-test report, and detailed control documentation available under NDA. DORA-aligned ICT third-party documentation provided for EU carriers on contract.</p>
      </details>
      <details>
        <summary>What about latency? We have sub-second SLAs.</summary>
        <p>Gateway adds ~30ms p50 / ~70ms p99 in EU and US regions. Policy evaluation runs in-memory; ledger writes are async and never block the response path. Sub-2s end-to-end for a typical Q&amp;A turn including grounding + price-accuracy checks.</p>
      </details>
      <details>
        <summary>How does pricing work?</summary>
        <p>Annual platform fee scaled to monitored traffic volume, plus a per-bundle fee on regulator exports. No per-query SaaS metering — it would incentivize under-logging, which defeats the purpose. Enterprise pricing negotiated directly. Indicative ranges available on a qualified call.</p>
      </details>
      <details>
        <summary>Do you support fine-tuned and self-hosted models?</summary>
        <p>Yes. Phidea is model-agnostic. Fine-tuned and self-hosted models are tagged separately in the cross-model funnel so you can compare their behavior against off-the-shelf. The policy engine doesn't care where the inference runs — it cares what came back.</p>
      </details>
      <details>
        <summary>How do you handle bias testing under Colorado SB21-169 and the NAIC bulletin?</summary>
        <p>Continuous testing against protected-class proxies in your live traffic, plus scheduled stress testing against synthetic personas calibrated to state-level demographic distributions. Results are exported in the format Colorado DOI accepts, with the underlying methodology documented for actuarial sign-off.</p>
      </details>
      <details>
        <summary>What happens to the platform if a model vendor changes their API?</summary>
        <p>The gateway abstracts the provider. Vendor API changes are absorbed at the Phidea layer with no carrier-side rework. Schema changes are versioned; old traces remain replayable against the policy pack version they were captured under.</p>
      </details>
      <details>
        <summary>Can we run an air-gapped pilot before signing?</summary>
        <p>Yes. Pilots run for four to six weeks against a designated AI surface, with a defined evidence-export milestone. No multi-year commit. The gateway and ledger ship as a container bundle for VPC or fully air-gapped deployments.</p>
      </details>
    </div>
  </section>

  <!-- CTA -->
  <section id="demo">
    <div class="wrap">
      <div class="cta-panel">
        <h2>See the platform on your AI surface.</h2>
        <p>Forty-five-minute working session. We instrument one of your live AI surfaces in read-only mode and walk you through the resulting trace, the policy evaluation, and a sample regulator bundle.</p>
        <form class="demo" action="https://phidea-forms.vercel.app/api/lead" method="POST">
          <input type="hidden" name="variant" value="insurance" />
          <input type="text" name="carrier" placeholder="Carrier or firm" required />
          <input type="email" name="email" placeholder="Work email" required />
          <button type="submit">Request a demo →</button>
        </form>
        <div class="cta-foot">Confidential. No mailing list. Replies routed to a Phidea solutions engineer.</div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .reg-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 8px;
    font-size: 14px;
  }
  .reg-table thead th {
    text-align: left;
    padding: 12px 16px;
    background: var(--soft);
    border-bottom: 1px solid var(--line);
    color: var(--ink-2);
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .reg-table tbody td {
    padding: 16px;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
    color: var(--ink-2);
    line-height: 1.5;
  }
  .reg-table tbody tr:hover td {
    background: var(--soft);
  }
  .reg-table tbody td:first-child {
    color: var(--ink);
    width: 18%;
  }
  .reg-table tbody td:nth-child(2) {
    width: 28%;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--accent);
  }

  .pullquote {
    max-width: 880px;
    margin: 0 auto;
    padding: 36px 40px;
    border-left: 3px solid var(--accent);
    background: var(--soft);
    border-radius: 0 14px 14px 0;
  }
  .pullquote p {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 22px;
    line-height: 1.45;
    margin: 0 0 16px;
    color: var(--ink);
    font-weight: 500;
  }
  .pullquote footer {
    font-size: 14px;
    color: var(--muted);
    font-style: normal;
  }

  .arch-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 8px;
  }
  .arch-step {
    padding: 28px;
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 14px;
  }
  .arch-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    color: var(--accent);
    margin-bottom: 12px;
    letter-spacing: 0.04em;
  }
  .arch-step h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 19px;
    line-height: 1.3;
    margin: 0 0 12px;
    color: var(--ink);
  }
  .arch-step p {
    color: var(--ink-2);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 720px) {
    .arch-grid { grid-template-columns: 1fr; }
    .reg-table { font-size: 13px; }
    .reg-table tbody td { padding: 12px 8px; }
    .pullquote { padding: 24px 20px; }
    .pullquote p { font-size: 18px; }
  }
</style>
