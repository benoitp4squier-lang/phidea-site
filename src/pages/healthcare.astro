---
import ReferenceArticle from "@/components/ReferenceArticle.astro";

const intro = [
  "Healthcare AI has two distinct regulatory paths. Medical-device software is regulated as a device: the US FDA under Software as a Medical Device (SaMD) rules, the EU under the Medical Device Regulation 2017/745. Non-device AI — clinical-decision support that sits outside device scope, revenue-cycle, administrative workflows — sits under privacy, consent, and transparency law.",
  "Both paths now intersect with the EU AI Act, which classifies medical-device AI as high-risk, and with ONC transparency rules in the US for certified health IT. This page catalogues the primary texts.",
];

const steps = [
  {
    label: "US — FDA Software as a Medical Device.",
    body: "FDA regulates AI/ML-based SaMD under the device framework. The <a href='https://www.fda.gov/medical-devices/software-medical-device-samd/artificial-intelligence-and-machine-learning-software-medical-device' target='_blank' rel='noopener'>FDA AI/ML SaMD page</a> collects guidance documents, including the AI/ML Action Plan (2021) and the Predetermined Change Control Plan guidance for continuously learning AI."
  },
  {
    label: "US — HIPAA and HITECH.",
    body: "The Health Insurance Portability and Accountability Act and the HITECH Act govern Protected Health Information. AI systems that access or process PHI sit under these rules — including privacy, security, and breach notification."
  },
  {
    label: "US — ONC HTI-1 Final Rule (January 2024).",
    body: "The Office of the National Coordinator's HTI-1 rule adds transparency and risk-management requirements for predictive decision support interventions in certified health IT. Developers must publish source attributes for each model."
  },
  {
    label: "EU — Medical Device Regulation 2017/745 and IVDR 2017/746.",
    body: "Regulation (EU) 2017/745 (MDR) and Regulation (EU) 2017/746 (IVDR) govern medical-device and in-vitro-diagnostic software across the EU. AI systems that meet the device definition fall under these regulations."
  },
  {
    label: "EU — AI Act (Regulation 2024/1689).",
    body: "Annex III classifies medical-device AI as high-risk. Obligations in Article 9 (risk management), Article 11 (technical documentation), Article 14 (human oversight) stack on top of MDR/IVDR requirements."
  },
  {
    label: "EU — GDPR (Regulation 2016/679).",
    body: "Applies to health-related personal data, with specific provisions for automated individual decisions under Article 22. Processing under GDPR is a distinct layer from MDR/IVDR device rules."
  },
];

const sources = [
  {
    label: "US — FDA",
    desc: "Software as a Medical Device (SaMD) documentation including AI/ML guidance.",
    urls: [
      { text: "fda.gov — AI/ML SaMD", url: "https://www.fda.gov/medical-devices/software-medical-device-samd/artificial-intelligence-and-machine-learning-software-medical-device" },
    ],
  },
  {
    label: "US — HHS / HIPAA",
    desc: "HIPAA Privacy and Security Rules.",
    urls: [
      { text: "hhs.gov — HIPAA", url: "https://www.hhs.gov/hipaa/index.html" },
    ],
  },
  {
    label: "US — ONC",
    desc: "HTI-1 Final Rule on health IT certification, including predictive decision support.",
    urls: [
      { text: "healthit.gov — HTI-1", url: "https://www.healthit.gov/topic/laws-regulation-and-policy/health-data-technology-and-interoperability-certification-program" },
    ],
  },
  {
    label: "EU — MDR / IVDR",
    desc: "Regulation 2017/745 (Medical Devices) and Regulation 2017/746 (In Vitro Diagnostics).",
    urls: [
      { text: "eur-lex.europa.eu — Regulation 2017/745", url: "https://eur-lex.europa.eu/eli/reg/2017/745/oj" },
      { text: "eur-lex.europa.eu — Regulation 2017/746", url: "https://eur-lex.europa.eu/eli/reg/2017/746/oj" },
    ],
  },
  {
    label: "EU — AI Act",
    desc: "Regulation (EU) 2024/1689. Medical-device AI classified as high-risk under Annex III.",
    urls: [
      { text: "eur-lex.europa.eu — Regulation 2024/1689", url: "https://eur-lex.europa.eu/eli/reg/2024/1689/oj" },
    ],
  },
  {
    label: "EU — GDPR",
    desc: "Regulation (EU) 2016/679. Article 22 covers automated individual decisions including profiling.",
    urls: [
      { text: "eur-lex.europa.eu — Regulation 2016/679", url: "https://eur-lex.europa.eu/eli/reg/2016/679/oj" },
    ],
  },
];
---

<ReferenceArticle
  variant="healthcare"
  tier="Industry · Healthcare"
  h1="AI in healthcare."
  standfirst="Two regulatory paths: medical-device software under FDA and MDR, non-device AI under HIPAA, GDPR, ONC, and the EU AI Act. Six primary texts cover most deployments."
  intro={intro}
  verifyTitle="The primary frameworks."
  steps={steps}
  sources={sources}
  newsletterHook="FDA AI/ML guidance as it lands, MDR and AI Act overlap for medical-device AI, and ONC HTI-1 transparency reporting patterns as hospitals implement them."
/>
