---
import ReferenceArticle from "@/components/ReferenceArticle.astro";

const intro = [
  "AI assistants like ChatGPT, Claude, Gemini, and Perplexity answer insurance questions every day. The assistants compose a sentence in response. That sentence sometimes names your carrier, sometimes names a competitor, and sometimes names no carrier at all.",
  "Whether your carrier gets named depends on what each model has read and what it retrieves at query time. The machinery has several layers, each with its own documentation and its own enforcement reality. Getting this right is a prerequisite for any serious measurement.",
];

const steps = [
  {
    label: "robots.txt is a request, not a block.",
    body: "OpenAI, Anthropic, Perplexity, and Google all state that their crawlers honour <code>robots.txt</code>. The protocol itself offers no enforcement mechanism. In June 2024, <a href='https://www.wired.com/story/perplexity-is-a-bullshit-machine/' target='_blank' rel='noopener'>Wired reported</a> that Perplexity retrieved content from pages that disallowed its declared user-agent, including retrieval via undeclared identifiers. Treat <code>robots.txt</code> as a statement of preference. If your risk posture requires an actual block, the enforcement layer is server-side.",
  },
  {
    label: "Training and retrieval are different pipelines.",
    body: "Each major provider runs more than one crawler, and the policies you set for one do not apply to the others. OpenAI separates <a href='https://platform.openai.com/docs/gptbot' target='_blank' rel='noopener'><code>GPTBot</code></a> (training-data ingestion) from <a href='https://platform.openai.com/docs/bots/chatgpt-user' target='_blank' rel='noopener'><code>ChatGPT-User</code></a> (user-triggered browsing inside a conversation) and <a href='https://platform.openai.com/docs/bots/oai-searchbot' target='_blank' rel='noopener'><code>OAI-SearchBot</code></a> (ChatGPT's search feature). Anthropic distinguishes <code>ClaudeBot</code> (training) from <code>Claude-Web</code> and <code>anthropic-ai</code> (live retrieval). Perplexity runs <code>PerplexityBot</code> alongside <code>Perplexity-User</code>. Blocking one does not block the others.",
  },
  {
    label: "Google-Extended is an opt-out token, not a crawler.",
    body: "A <code>User-agent: Google-Extended</code> disallow tells Google not to use your content to train Gemini or Vertex AI. <a href='https://developers.google.com/search/docs/crawling-indexing/google-crawlers' target='_blank' rel='noopener'>Googlebot</a> continues to crawl your site for regular search under its own rules. AI Overviews, which compose answers at query time from the regular search index, are not controlled by Google-Extended at all; that requires different mechanisms (Search Console no-snippet directives, or absence from search altogether).",
  },
  {
    label: "The crawler list is longer than the four majors.",
    body: "Meta's <code>Meta-ExternalAgent</code>, Apple's <code>Applebot-Extended</code>, ByteDance's <code>Bytespider</code>, Amazon's <code>Amazonbot</code>, and Cohere's <code>cohere-ai</code> all identify themselves and are documented. Each sits in the same voluntary-compliance bucket. <a href='https://darkvisitors.com/agents' target='_blank' rel='noopener'>Dark Visitors</a> maintains a continuously updated list with the <code>robots.txt</code> syntax each expects. Any audit that treats four providers as the full surface is incomplete.",
  },
  {
    label: "Real enforcement is server-side.",
    body: "If you want a block rather than a request, the enforcement layer is your web application firewall or CDN: user-agent and IP-range filtering, <a href='https://blog.cloudflare.com/declaring-your-aindependence-block-ai-bots-scrapers-and-crawlers-with-a-single-click/' target='_blank' rel='noopener'>Cloudflare's AI Scrapers and Crawlers rule set</a>, or equivalent controls on your edge provider. These can be combined with <code>robots.txt</code>, but <code>robots.txt</code> on its own is not a barrier.",
  },
  {
    label: "Even full blocking does not make you invisible.",
    body: "Models retain knowledge from crawls that predated your policy. They also reach you through third-party sources that mention you — comparison media, trade press, Wikipedia — and through structured-data feeds your partners maintain. Blocking every AI crawler does not remove what was ingested earlier and does not stop live retrieval of pages that link to you. Controlling what the model says about you is a combination of blocking, correcting third-party sources, and providing clearer material in the channels that remain open.",
  },
  {
    label: "The one measurement you can always run.",
    body: "Pick twenty to forty real buyer questions in your market, in the local language. Run them against each of the four major assistants. Note who is cited, by name, in each answer. Compare the distribution with your actual market share. The result is your current citation rate on each surface. It is repeatable, it costs nothing but time, and it gives you a number you can defend in a conversation with marketing, compliance, or the board.",
  },
];

const sources = [
  {
    label: "OpenAI",
    desc: "Three separate crawlers: GPTBot (training), ChatGPT-User (user-triggered browsing), OAI-SearchBot (ChatGPT search). Each is documented independently.",
    urls: [
      { text: "platform.openai.com/docs/gptbot", url: "https://platform.openai.com/docs/gptbot" },
      { text: "platform.openai.com — overview of crawlers", url: "https://platform.openai.com/docs/bots/overview-of-openai-crawlers" },
    ],
  },
  {
    label: "Anthropic",
    desc: "ClaudeBot (training), Claude-Web and anthropic-ai (live retrieval). robots.txt conformance statement.",
    urls: [
      { text: "support.anthropic.com — Anthropic crawler", url: "https://support.anthropic.com/en/articles/8896518-does-anthropic-crawl-data-from-the-web-and-how-can-site-owners-block-the-crawler" },
    ],
  },
  {
    label: "Perplexity",
    desc: "PerplexityBot (training) and Perplexity-User (live retrieval). See also the Wired investigation on non-compliance.",
    urls: [
      { text: "perplexity.ai — crawler user-agents", url: "https://www.perplexity.ai/help-center/en/articles/10163415-perplexity-crawlers-user-agents" },
      { text: "Wired — Perplexity Is a Bullshit Machine (Jun 2024)", url: "https://www.wired.com/story/perplexity-is-a-bullshit-machine/" },
    ],
  },
  {
    label: "Google",
    desc: "Google-Extended is an opt-out token for Gemini and Vertex AI training. Googlebot remains the search crawler and is separate.",
    urls: [
      { text: "developers.google.com — Google-Extended", url: "https://developers.google.com/search/docs/crawling-indexing/google-extended" },
      { text: "developers.google.com — overview of Google crawlers", url: "https://developers.google.com/search/docs/crawling-indexing/google-crawlers" },
    ],
  },
  {
    label: "Other AI crawlers",
    desc: "Meta-ExternalAgent, Applebot-Extended, Bytespider, Amazonbot, cohere-ai — each documented by its provider. Dark Visitors maintains the canonical cross-provider list.",
    urls: [
      { text: "darkvisitors.com/agents", url: "https://darkvisitors.com/agents" },
      { text: "developer.apple.com — Applebot-Extended", url: "https://developer.apple.com/support/applebot/" },
    ],
  },
  {
    label: "Enforcement",
    desc: "If voluntary compliance is insufficient, the server-side blocking layer is your CDN or WAF. Cloudflare ships dedicated AI-crawler rules.",
    urls: [
      { text: "Cloudflare — block AI bots", url: "https://blog.cloudflare.com/declaring-your-aindependence-block-ai-bots-scrapers-and-crawlers-with-a-single-click/" },
    ],
  },
];
---

<ReferenceArticle
  variant="ai-visibility"
  tier="Topic 01 · Distribution"
  h1="When a carrier isn't cited by ChatGPT."
  standfirst="Your Google rank and your ChatGPT citation rate are not the same number. This page is the starting reference."
  intro={intro}
  verifyTitle="What you can verify this afternoon."
  steps={steps}
  sources={sources}
  newsletterHook="How the crawler list changes week to week, which carriers are moving on share-of-answer, and what shows up when we rerun forty-query probes against the four major assistants."
/>
