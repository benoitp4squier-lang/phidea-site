---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";

const navLinks = [
  { href: "/distribution.html", label: "Distribution" },
  { href: "/synthetic.html", label: "Monitoring" },
  { href: "/evidence.html", label: "Governance" },
  { href: "#faq", label: "FAQ" },
];
const navCta = { href: "#demo", label: "Request a demo →" };
---

<Layout variant="flagship-observability">
  <Nav variant="flagship-observability" links={navLinks} cta={navCta} />

  <header class="hero">
    <div class="wrap">
      <span class="eyebrow">AI governance for insurers</span>
      <h1>AI supports underwriting. <em>It does not replace it.</em> A regulator can now check.</h1>
      <p class="lead">
        Phidea is the governance layer around every AI model your insurer runs — in underwriting, claims, distribution, or the ChatGPT surface a buyer just opened.
      </p>
      <div class="cta-row">
        <a href="#demo" class="btn btn-primary">Request a demo →</a>
        <a href="#paths" class="btn btn-ghost">Where are you today?</a>
      </div>
      <div class="hero-meta">
        <span><strong>Design partner:</strong> Tier-1 European carrier</span>
        <span><strong>Private beta</strong> · 3 more carriers, Q2 2026</span>
        <span><strong>EU-hosted</strong> · VPC and on-prem available</span>
      </div>
    </div>
  </header>

  <section class="trust" style="padding: 36px 0; border-bottom: 1px solid var(--line);">
    <div class="wrap">
      <div class="trust-label">Mapped to</div>
      <div class="trust-items">
        <span class="chip">NAIC Model Bulletin</span>
        <span class="chip">NY DFS Circular Letter No. 7</span>
        <span class="chip">Colorado SB21-169</span>
        <span class="chip">EU AI Act Annex III</span>
        <span class="chip">IDD / ACPR</span>
        <span class="chip">DORA</span>
      </div>
    </div>
  </section>

  <section id="paths" style="padding: 88px 0;">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">Three starting points</div>
        <h2>Pick the one that sounds like your week.</h2>
      </div>

      <div class="angle-grid">
        <a class="angle-card" href="/distribution.html">
          <div class="tag">Distribution · CMO · Head of Digital</div>
          <h3>Buyers are asking ChatGPT about your products. You don't know what it's answering.</h3>
          <p>Scan your share of answer across ChatGPT, Claude, Gemini, Perplexity. See who's cited instead. Ship a governed AI app of your own.</p>
          <div class="url">phidea.eu/distribution</div>
        </a>

        <a class="angle-card" href="/synthetic.html">
          <div class="tag">Monitoring · Head of AI · AI-ops</div>
          <h3>You shipped an AI agent. Models drift. Auditors check annually.</h3>
          <p>Every prompt, every response, graded in real time. Hallucinations classifier. Synthetic-buyer red-teaming around the clock.</p>
          <div class="url">phidea.eu/synthetic</div>
        </a>

        <a class="angle-card" href="/evidence.html">
          <div class="tag">Governance · Compliance · Legal · Risk</div>
          <h3>Your AIS Program is on paper. A DFS examiner will ask for evidence.</h3>
          <p>ECDIS log, adverse-decision trail, policy-pack mapping to NAIC Model Bulletin and NY DFS Circular Letter No. 7. Audit bundle in one click.</p>
          <div class="url">phidea.eu/evidence</div>
        </a>
      </div>
    </div>
  </section>

  <section id="category" style="padding: 88px 0; background: var(--soft); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">Why this is a new category</div>
        <h2>Vanta won SOC 2. The same window is open for AI in regulated commerce.</h2>
        <p class="lead">
          AI systems in insurance left pilot last year. Regulation ships every quarter — NAIC bulletin, NY DFS Circular Letter No. 7, Colorado SB21-169, EU AI Act Annex III. Internal governance frameworks were built for static documentation, not live inference. One, maybe two, platforms will own the compliance layer. Phidea is going after it.
        </p>
      </div>
    </div>
  </section>

  <section id="faq" style="padding: 88px 0;">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">FAQ</div>
        <h2>Straight answers.</h2>
      </div>
      <details>
        <summary>Is this a red-teaming tool?</summary>
        <p>Red-teaming is episodic. Phidea runs every hour, against your live AI, with the regulatory probe library updated per bulletin.</p>
      </details>
      <details>
        <summary>Will you stop a bad answer before a customer sees it?</summary>
        <p>Yes, optionally. Phidea sits as a policy gate in front of your agent. Most carriers start in observe-only and turn blocking on after 30 days of clean traces.</p>
      </details>
      <details>
        <summary>What does "private beta" mean for us?</summary>
        <p>The platform is in production with one tier-1 European carrier and onboarding three more in Q2. Design partners get founding pricing and co-authored case studies.</p>
      </details>
      <details>
        <summary>What does it cost?</summary>
        <p>Low five figures annual for a single line, single region. Scales by LOB and jurisdiction. Priced after a 30-minute demo — not before.</p>
      </details>
      <details>
        <summary>Where is Phidea hosted?</summary>
        <p>EU regions (Frankfurt, Paris) by default. VPC or on-prem for carriers with that requirement. Nothing phones home from an air-gapped deployment.</p>
      </details>
    </div>
  </section>

  <section id="demo" style="padding: 88px 0;">
    <div class="wrap">
      <div class="cta-panel" style="text-align: center; max-width: 720px; margin: 0 auto;">
        <h2>See a live probe against your own AI.</h2>
        <p>Thirty-minute demo. We run a probe suite against whichever surface you name. You see the traces, the flags, and the evidence bundle at the end. No slides.</p>
        <form action="https://phidea-forms.vercel.app/api/lead" method="POST" style="max-width: 480px; margin: 0 auto; display: flex; flex-direction: column; gap: 12px;">
          <input type="hidden" name="variant" value="flagship-observability" />
          <input type="email" name="email" placeholder="work@carrier.com" required
            style="padding: 14px 16px; border: 1px solid var(--line); border-radius: 10px; font-size: 15px;" />
          <input type="text" name="carrier" placeholder="Carrier name" required
            style="padding: 14px 16px; border: 1px solid var(--line); border-radius: 10px; font-size: 15px;" />
          <button type="submit" class="btn btn-primary" style="align-self: center;">
            Request a demo →
          </button>
        </form>
        <div class="cta-foot">
          Reply within one business day. Private beta — qualified insurer contacts only.
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
