---
import ReferenceArticle from "@/components/ReferenceArticle.astro";

const intro = [
  "Augmented underwriting is the practice of using automation, rules-as-code, and increasingly AI-assisted retrieval to reduce the time underwriters spend on routine submission handling. The 2025 State of Pricing industry report quantifies the problem: specialty and commercial underwriters report spending significant time on manual referral triage.",
  "The technology layer is varied and documented; the governance and licensing layer is insurance-specific and primary-text-sourced.",
];

const steps = [
  {
    label: "One, industry benchmark.",
    body: "The <a href='https://www.hyperexponential.com/resources/2025-state-of-pricing-report' target='_blank' rel='noopener'>hyperexponential 2025 State of Pricing report</a> surveys 350 specialty and commercial underwriters and pricing actuaries. The headline finding on pricing-model freshness: 45% report their models are out of date or inaccurate. The report breaks the data down by line, region, and function."
  },
  {
    label: "Two, authority and licensing.",
    body: "Decisions made by an augmented-underwriting system are still bound by the carrier's authority letters and the producer-licensing rules of the jurisdiction. In the US, state producer-licensing law governs; in the EU, <a href='https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32016L0097' target='_blank' rel='noopener'>IDD (Directive 2016/97)</a> and transposing national law apply."
  },
  {
    label: "Three, governance under the NAIC bulletin.",
    body: "The <a href='https://content.naic.org/sites/default/files/inline-files/2023-12-4%20Model%20Bulletin_Adopted_0.pdf' target='_blank' rel='noopener'>NAIC Model Bulletin on AI Systems</a> covers AI use in underwriting. Augmented underwriting is within scope; the AIS Program expectations apply."
  },
  {
    label: "Four, policy-as-code patterns.",
    body: "Rules-as-code is an established pattern with open-source implementations (<a href='https://www.openpolicyagent.org/' target='_blank' rel='noopener'>Open Policy Agent</a>, Cedar, Rego). The pattern is independent of AI; combining it with AI-assisted feature extraction is the insurance-specific application."
  },
];

const sources = [
  {
    label: "Industry survey",
    desc: "hyperexponential 2025 State of Pricing — survey of 350 specialty and commercial underwriters and pricing actuaries.",
    urls: [
      { text: "hyperexponential.com — 2025 report", url: "https://www.hyperexponential.com/resources/2025-state-of-pricing-report" },
    ],
  },
  {
    label: "EU — IDD",
    desc: "Directive (EU) 2016/97 on insurance distribution, including information, advice, and suitability obligations.",
    urls: [
      { text: "eur-lex.europa.eu — Directive 2016/97", url: "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32016L0097" },
    ],
  },
  {
    label: "US — NAIC",
    desc: "Model Bulletin on the Use of AI Systems by Insurers.",
    urls: [
      { text: "Model Bulletin (PDF)", url: "https://content.naic.org/sites/default/files/inline-files/2023-12-4%20Model%20Bulletin_Adopted_0.pdf" },
    ],
  },
  {
    label: "Open-source tooling",
    desc: "Open Policy Agent — the CNCF-graduated project for policy-as-code.",
    urls: [
      { text: "openpolicyagent.org", url: "https://www.openpolicyagent.org/" },
    ],
  },
];
---

<ReferenceArticle
  variant="augmented-underwriting"
  tier="Topic 17 · Model risk"
  h1="Give underwriters their three hours back."
  standfirst="Policy-as-code plus AI-assisted triage. The industry benchmark is public; the regulatory layer is primary-text-sourced."
  intro={intro}
  verifyTitle="The primary references."
  steps={steps}
  sources={sources}
  newsletterHook="Which carriers are shipping policy-as-code in underwriting, how authority letters translate into runtime rules, and what the early audit findings look like."
/>
