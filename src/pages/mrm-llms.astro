---
import ReferenceArticle from "@/components/ReferenceArticle.astro";

const intro = [
  "Model Risk Management (MRM) frameworks predate large language models by a decade. SR 11-7 (US Federal Reserve and OCC, 2011), OCC Bulletin 2011-12, and PRA SS1/23 (UK, 2023) define the supervisory expectations. The frameworks are framework-agnostic on the model type; they were written for statistical and econometric models but apply to any model used in decision-making.",
  "The practical question for an insurance actuarial or risk function is which controls translate to LLMs, and which require extension. The primary texts remain the anchor.",
];

const steps = [
  {
    label: "One, SR 11-7 — the foundational US framework.",
    body: "The <a href='https://www.federalreserve.gov/supervisionreg/srletters/sr1107.htm' target='_blank' rel='noopener'>Federal Reserve's Supervisory Letter SR 11-7</a>, issued jointly with <a href='https://www.occ.treas.gov/news-issuances/bulletins/2011/bulletin-2011-12.html' target='_blank' rel='noopener'>OCC Bulletin 2011-12</a>, establishes the US MRM framework: model inventory, development-and-implementation controls, validation (including ongoing monitoring and outcomes analysis), and governance."
  },
  {
    label: "Two, PRA SS1/23 — the UK approach.",
    body: "The Bank of England's <a href='https://www.bankofengland.co.uk/prudential-regulation/publication/2023/may/model-risk-management-principles-for-banks' target='_blank' rel='noopener'>Supervisory Statement 1/23</a> (Model Risk Management Principles for Banks), published May 2023, updates and modernises the UK model risk expectations. It introduces outcome-based controls that sit well alongside LLM-specific telemetry."
  },
  {
    label: "Three, EU AI Act — high-risk AI overlap.",
    body: "<a href='https://eur-lex.europa.eu/eli/reg/2024/1689/oj' target='_blank' rel='noopener'>Regulation 2024/1689 (AI Act)</a> Article 9 requires a risk management system for high-risk AI; Article 15 covers accuracy, robustness, and cybersecurity; Article 61 covers post-market monitoring. For insurance AI classified as high-risk under Annex III, these overlap materially with MRM expectations."
  },
  {
    label: "Four, NAIC Model Bulletin — insurance scope.",
    body: "The <a href='https://content.naic.org/sites/default/files/inline-files/2023-12-4%20Model%20Bulletin_Adopted_0.pdf' target='_blank' rel='noopener'>NAIC Model Bulletin</a> applies MRM-like expectations specifically to AI Systems used by insurers. It is not positioned as an MRM framework in the SR 11-7 sense but it covers similar ground — governance, testing, validation, third-party oversight."
  },
];

const sources = [
  {
    label: "US — Fed / OCC",
    desc: "SR 11-7 and OCC Bulletin 2011-12, the US MRM supervisory framework.",
    urls: [
      { text: "SR 11-7 — Fed Reserve", url: "https://www.federalreserve.gov/supervisionreg/srletters/sr1107.htm" },
      { text: "OCC Bulletin 2011-12", url: "https://www.occ.treas.gov/news-issuances/bulletins/2011/bulletin-2011-12.html" },
    ],
  },
  {
    label: "UK — PRA",
    desc: "SS1/23 Model Risk Management Principles for Banks.",
    urls: [
      { text: "bankofengland.co.uk — SS1/23", url: "https://www.bankofengland.co.uk/prudential-regulation/publication/2023/may/model-risk-management-principles-for-banks" },
    ],
  },
  {
    label: "EU — AI Act",
    desc: "Regulation 2024/1689. Articles 9 (risk management), 15 (accuracy and robustness), 61 (post-market monitoring).",
    urls: [
      { text: "eur-lex.europa.eu — Regulation 2024/1689", url: "https://eur-lex.europa.eu/eli/reg/2024/1689/oj" },
    ],
  },
  {
    label: "US — NAIC",
    desc: "Model Bulletin on the Use of AI Systems by Insurers.",
    urls: [
      { text: "Model Bulletin (PDF)", url: "https://content.naic.org/sites/default/files/inline-files/2023-12-4%20Model%20Bulletin_Adopted_0.pdf" },
    ],
  },
];
---

<ReferenceArticle
  variant="mrm-llms"
  tier="Topic 15 · Model risk"
  h1="MRM extended to LLMs."
  standfirst="SR 11-7, PRA SS1/23, the AI Act, and the NAIC bulletin. The primary texts you map an MRM extension against."
  intro={intro}
  verifyTitle="The primary texts."
  steps={steps}
  sources={sources}
  newsletterHook="Which MRM functions are extending to LLMs first, where SR 11-7 validation doctrine runs out against generative systems, and how the EU AI Act and NAIC expectations are being integrated in practice."
/>
