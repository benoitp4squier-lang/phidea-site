---
import ReferenceArticle from "@/components/ReferenceArticle.astro";

const intro = [
  "A Custom GPT, a Claude MCP server, or a Gemini Extension is a way to surface your carrier's products inside an assistant. Each provider documents the build and deployment model publicly. The question of whether the resulting agent complies with insurance distribution law is a separate layer, governed in the EU by the Insurance Distribution Directive (IDD) and, in the US, by state distribution and unfair-trade-practice statutes.",
  "This page collects the primary technical and regulatory references. It does not evaluate compliance; that is a carrier-specific exercise with your legal and compliance teams.",
];

const steps = [
  {
    label: "One, the technical surfaces.",
    body: "Three documented surfaces today: <a href='https://platform.openai.com/docs/actions' target='_blank' rel='noopener'>OpenAI's Custom GPT and Actions</a>, <a href='https://modelcontextprotocol.io' target='_blank' rel='noopener'>Anthropic's Model Context Protocol (MCP)</a>, and <a href='https://developers.google.com/gemini' target='_blank' rel='noopener'>Google's Gemini API and extensions</a>. Each has its own deployment model, authentication story, and rate-limit posture."
  },
  {
    label: "Two, the distribution law that applies.",
    body: "In the EU, <a href='https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32016L0097' target='_blank' rel='noopener'>IDD (Directive 2016/97)</a> governs insurance distribution including advice, comparison, and product information. Article 20 in particular addresses demands-and-needs analysis and suitability. In the US, the NAIC Unfair Trade Practices Act framework and state-by-state producer-licensing rules apply; the <a href='https://content.naic.org/sites/default/files/inline-files/2023-12-4%20Model%20Bulletin_Adopted_0.pdf' target='_blank' rel='noopener'>NAIC Model Bulletin on the Use of AI</a> extends those rules to AI-assisted channels."
  },
  {
    label: "Three, the AI-specific compliance layer.",
    body: "<a href='https://www.dfs.ny.gov/industry-guidance/circular-letters/cl2024-07' target='_blank' rel='noopener'>NY DFS Circular Letter No. 7 of 2024</a> addresses External Consumer Data and Information Sources and requires that AI-driven decisions rest on a clear, empirical, statistically significant, rational, and not-unfairly-discriminatory relationship to the insured risk. This standard applies to AI-assistant-mediated distribution where any decision, including routing or recommendation, touches the consumer."
  },
  {
    label: "Four, what each assistant does with prices.",
    body: "Any agent that surfaces prices must read them from your pricing API at runtime. Relying on the model's own composition of a number is not acceptable under audit, regardless of how accurately the model paraphrased your public page. The pricing API is the source of truth; the model is a layer over it."
  },
];

const sources = [
  {
    label: "OpenAI",
    desc: "Custom GPT builder, Actions (tool calling), and API authentication.",
    urls: [
      { text: "platform.openai.com/docs/actions", url: "https://platform.openai.com/docs/actions" },
      { text: "help.openai.com — Custom GPTs", url: "https://help.openai.com/en/articles/8554397-creating-a-gpt" },
    ],
  },
  {
    label: "Anthropic",
    desc: "Model Context Protocol (MCP) — the open specification for agent-to-tool connections that Claude natively supports.",
    urls: [
      { text: "modelcontextprotocol.io", url: "https://modelcontextprotocol.io" },
      { text: "docs.anthropic.com — MCP", url: "https://docs.anthropic.com/en/docs/mcp" },
    ],
  },
  {
    label: "Google",
    desc: "Gemini API, extensions, and function calling documentation.",
    urls: [
      { text: "ai.google.dev — Gemini API", url: "https://ai.google.dev/gemini-api/docs" },
    ],
  },
  {
    label: "EU — IDD",
    desc: "Insurance Distribution Directive, full consolidated text on EUR-Lex.",
    urls: [
      { text: "eur-lex.europa.eu — Directive 2016/97", url: "https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX:32016L0097" },
    ],
  },
  {
    label: "US — NAIC",
    desc: "Model Bulletin on the Use of Artificial Intelligence Systems by Insurers (Dec 2023) and state-adoption tracker.",
    urls: [
      { text: "content.naic.org — Model Bulletin PDF", url: "https://content.naic.org/sites/default/files/inline-files/2023-12-4%20Model%20Bulletin_Adopted_0.pdf" },
      { text: "content.naic.org — AI topic page", url: "https://content.naic.org/cipr-topics/artificial-intelligence" },
    ],
  },
  {
    label: "US — NY DFS",
    desc: "Circular Letter No. 7 of 2024 on the Use of Artificial Intelligence and External Consumer Data.",
    urls: [
      { text: "dfs.ny.gov — CL 2024-07", url: "https://www.dfs.ny.gov/industry-guidance/circular-letters/cl2024-07" },
    ],
  },
];
---

<ReferenceArticle
  variant="custom-gpt"
  tier="Topic 03 · Distribution"
  h1="A Custom GPT your compliance team can sign off on."
  standfirst="The technical build is documented. The regulatory layer is where most carrier projects halt. This page indexes both."
  intro={intro}
  verifyTitle="What you can verify before starting the build."
  steps={steps}
  sources={sources}
  newsletterHook="Which carriers are shipping agents in production and where compliance actually held the launch. Changes to the provider APIs and the regulator guidance as they appear."
/>
