---
import ReferenceArticle from "@/components/ReferenceArticle.astro";

const intro = [
  "Protected-class testing for insurance AI systems has different legal bases in different jurisdictions. In the United States, the binding frameworks are state-level: Colorado SB21-169 (life), NY DFS Circular Letter No. 7 (all lines authorised in New York), and state unfair-trade-practice statutes modeled on the NAIC Model Bulletin.",
  "Each defines the test differently. Quantitative, proxy-aware, and demographic-calibrated are the three common characteristics; the specific methodology is prescribed in Colorado and open-framework elsewhere.",
];

const steps = [
  {
    label: "One, Colorado SB21-169 — the codified test.",
    body: "<a href='https://leg.colorado.gov/bills/sb21-169' target='_blank' rel='noopener'>SB21-169</a> applies to life insurers. The implementing regulation from the <a href='https://doi.colorado.gov/for-consumers/sb21-169-protecting-consumers-from-unfair-discrimination-in-insurance-practices' target='_blank' rel='noopener'>Colorado Division of Insurance</a> specifies the quantitative testing methodology, including demographic baselines and required proxy-variable review."
  },
  {
    label: "Two, NY DFS — unfair discrimination as a statutory standard.",
    body: "<a href='https://www.dfs.ny.gov/industry-guidance/circular-letters/cl2024-07' target='_blank' rel='noopener'>Circular Letter No. 7 of 2024</a> requires that the relationship between variables used and the insured risk be not unfairly discriminatory. The Insurance Law underpinning this (Article 26 and related provisions) is the statutory standard; the Circular Letter sets the interpretation."
  },
  {
    label: "Three, NAIC — the wider framework.",
    body: "The <a href='https://content.naic.org/sites/default/files/inline-files/2023-12-4%20Model%20Bulletin_Adopted_0.pdf' target='_blank' rel='noopener'>NAIC Model Bulletin</a> expects bias documentation across lines and states that are adopting. Implementation and scope vary by state adoption."
  },
  {
    label: "Four, EU — AI Act non-discrimination.",
    body: "The <a href='https://eur-lex.europa.eu/eli/reg/2024/1689/oj' target='_blank' rel='noopener'>AI Act (Regulation 2024/1689)</a>, Article 10, addresses data-governance obligations for high-risk AI, including identification of data gaps or shortcomings that could lead to non-compliance with Union non-discrimination law."
  },
  {
    label: "Five, academic reference.",
    body: "The <a href='https://facctconference.org' target='_blank' rel='noopener'>ACM FAccT conference</a> is the leading academic venue for fairness, accountability, and transparency research. Standard protected-class proxy analyses, disparate-impact tests, and fairness metrics are documented in its proceedings."
  },
];

const sources = [
  {
    label: "US — Colorado",
    desc: "SB21-169 text and Colorado DOI implementing-regulation page.",
    urls: [
      { text: "leg.colorado.gov — SB21-169", url: "https://leg.colorado.gov/bills/sb21-169" },
      { text: "doi.colorado.gov — SB21-169 page", url: "https://doi.colorado.gov/for-consumers/sb21-169-protecting-consumers-from-unfair-discrimination-in-insurance-practices" },
    ],
  },
  {
    label: "US — NY DFS",
    desc: "Circular Letter No. 7 of 2024 on AI Systems and unfair discrimination.",
    urls: [
      { text: "dfs.ny.gov — CL 2024-07", url: "https://www.dfs.ny.gov/industry-guidance/circular-letters/cl2024-07" },
    ],
  },
  {
    label: "US — NAIC",
    desc: "Model Bulletin and AI topic page with state-adoption tracker.",
    urls: [
      { text: "Model Bulletin (PDF)", url: "https://content.naic.org/sites/default/files/inline-files/2023-12-4%20Model%20Bulletin_Adopted_0.pdf" },
      { text: "NAIC AI topic", url: "https://content.naic.org/cipr-topics/artificial-intelligence" },
    ],
  },
  {
    label: "EU — AI Act",
    desc: "Regulation 2024/1689, Article 10 on data governance and non-discrimination.",
    urls: [
      { text: "eur-lex.europa.eu — Regulation 2024/1689", url: "https://eur-lex.europa.eu/eli/reg/2024/1689/oj" },
    ],
  },
  {
    label: "Academic reference",
    desc: "ACM FAccT — Conference on Fairness, Accountability, and Transparency; a public source for bias-testing methodologies.",
    urls: [
      { text: "facctconference.org", url: "https://facctconference.org" },
    ],
  },
];
---

<ReferenceArticle
  variant="bias-testing"
  tier="Topic 14 · Compliance"
  h1="Protected-class testing, per jurisdiction."
  standfirst="Colorado defines the test. NY DFS sets the standard. NAIC expects the documentation. The EU AI Act adds data governance."
  intro={intro}
  verifyTitle="What the primary texts require."
  steps={steps}
  sources={sources}
  newsletterHook="Evolving methodologies in Colorado DOI filings, NY DFS examination patterns, and revisions to state-level NAIC bulletin adoption affecting bias-testing scope."
/>
