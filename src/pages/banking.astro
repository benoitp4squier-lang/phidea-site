---
import ReferenceArticle from "@/components/ReferenceArticle.astro";

const intro = [
  "Banking has had a named model risk management framework since 2011. SR 11-7 was the foundational US supervisory letter. As of April 2026 it has been superseded by SR 26-2, with OCC Bulletin 2026-13 revising the companion national-bank guidance. The governance architecture is the same; the scope and language are updated for LLMs and generative AI.",
  "The UK refresh landed earlier (PRA SS1/23, May 2023). The EU adds two layers: AI Act credit-scoring provisions and DORA. This page catalogues the primary texts in force, plus the legacy ones still referenced in policy memos.",
];

const steps = [
  {
    label: "US — SR 26-2 (current) and OCC Bulletin 2026-13.",
    body: "The <a href='https://www.federalreserve.gov/supervisionreg/srletters/SR2602.htm' target='_blank' rel='noopener'>Federal Reserve's SR 26-2</a> (April 17, 2026) supersedes SR 11-7 on Model Risk Management. <a href='https://www.occ.treas.gov/news-issuances/bulletins/2026/bulletin-2026-13.html' target='_blank' rel='noopener'>OCC Bulletin 2026-13</a> revises the national-bank MRM guidance in parallel. Inventory, validation, outcomes monitoring, and governance carry through from the 2011 framework; the updated text explicitly contemplates LLMs."
  },
  {
    label: "US — SR 11-7 and OCC Bulletin 2011-12 (legacy).",
    body: "<a href='https://www.federalreserve.gov/supervisionreg/srletters/sr1107.htm' target='_blank' rel='noopener'>SR 11-7</a> and <a href='https://www.occ.treas.gov/news-issuances/bulletins/2011/bulletin-2011-12.html' target='_blank' rel='noopener'>OCC Bulletin 2011-12</a> remain heavily referenced in existing MRM documentation and continuing-education curricula. A bank's model inventory is likely still mapped to the 2011 vocabulary; the 2026 refresh extends rather than rebuilds it."
  },
  {
    label: "UK — PRA Supervisory Statement 1/23.",
    body: "<a href='https://www.bankofengland.co.uk/prudential-regulation/publication/2023/may/model-risk-management-principles-for-banks-ss' target='_blank' rel='noopener'>SS1/23</a>, in force from May 17, 2024. Outcome-based controls that translate cleanly to LLM telemetry: grounding, refusal, behavioural fingerprints, challenger comparison."
  },
  {
    label: "US — CFPB Circular 2023-03.",
    body: "<a href='https://www.consumerfinance.gov/about-us/newsroom/cfpb-issues-guidance-on-credit-denials-by-lenders-using-artificial-intelligence/' target='_blank' rel='noopener'>CFPB Circular 2023-03</a> on adverse-action notices for complex AI/ML credit models. ECOA and Reg B obligations apply regardless of model complexity; a credit model's AI nature does not reduce the notice requirements."
  },
  {
    label: "US — NYDFS Industry Letter (Oct 16, 2024).",
    body: "<a href='https://www.dfs.ny.gov/industry-guidance/industry-letters/il20241016-cyber-risks-ai-and-strategies-combat-related-risks' target='_blank' rel='noopener'>NYDFS Industry Letter of October 16, 2024</a> on AI cybersecurity under 23 NYCRR Part 500. Covers the specific adversarial-AI threat posture expected of New York-authorised financial institutions."
  },
  {
    label: "EU — AI Act (Regulation 2024/1689).",
    body: "<a href='https://eur-lex.europa.eu/eli/reg/2024/1689/oj' target='_blank' rel='noopener'>Regulation 2024/1689</a> classifies creditworthiness assessment as a high-risk AI use under Annex III. Articles 9 (risk management), 11 (technical documentation), 14 (human oversight) apply to banks using AI in credit decisioning."
  },
  {
    label: "EU — DORA (Regulation 2022/2554).",
    body: "<a href='https://eur-lex.europa.eu/eli/reg/2022/2554/oj' target='_blank' rel='noopener'>DORA</a> covers banks as financial entities. ICT third-party risk Register of Information, incident classification, resilience testing. Obligations apply from January 2025."
  },
  {
    label: "International — FSB and Basel.",
    body: "The <a href='https://www.fsb.org/2024/11/the-financial-stability-implications-of-artificial-intelligence/' target='_blank' rel='noopener'>FSB's Financial Stability Implications of AI</a> (Nov 2024) and <a href='https://www.bis.org/publ/bcbs_nl27.htm' target='_blank' rel='noopener'>BCBS Newsletter on AI/ML</a> set the international supervisory direction. BCBS 239 on risk data aggregation is the legacy anchor that supervisors apply to AI data governance."
  },
];

const sources = [
  {
    label: "US — Fed / OCC",
    desc: "The current and legacy US model-risk supervisory framework.",
    urls: [
      { text: "federalreserve.gov — SR 26-2 (current)", url: "https://www.federalreserve.gov/supervisionreg/srletters/SR2602.htm" },
      { text: "occ.treas.gov — Bulletin 2026-13 (current)", url: "https://www.occ.treas.gov/news-issuances/bulletins/2026/bulletin-2026-13.html" },
      { text: "federalreserve.gov — SR 11-7 (legacy)", url: "https://www.federalreserve.gov/supervisionreg/srletters/sr1107.htm" },
      { text: "occ.treas.gov — Bulletin 2011-12 (legacy)", url: "https://www.occ.treas.gov/news-issuances/bulletins/2011/bulletin-2011-12.html" },
      { text: "occ.gov — Semiannual Risk Perspective (Fall 2025)", url: "https://www.occ.gov/publications-and-resources/publications/semiannual-risk-perspective/files/pub-semiannual-risk-perspective-fall-2025.pdf" },
    ],
  },
  {
