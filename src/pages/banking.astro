    desc: "Supervisory Statement 1/23 Model Risk Management Principles for Banks, plus the 2025 CRO roundtable readout.",
    urls: [
      { text: "bankofengland.co.uk — SS1/23", url: "https://www.bankofengland.co.uk/prudential-regulation/publication/2023/may/model-risk-management-principles-for-banks-ss" },
      { text: "bankofengland.co.uk — PRA MRM AI roundtable (Nov 2025)", url: "https://www.bankofengland.co.uk/prudential-regulation/publication/2025/november/pra-holds-model-risk-management-roundtable-on-ai" },
    ],
  },
