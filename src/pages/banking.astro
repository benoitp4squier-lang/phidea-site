      { text: "consumerfinance.gov — Circular 2023-03", url: "https://www.consumerfinance.gov/about-us/newsroom/cfpb-issues-guidance-on-credit-denials-by-lenders-using-artificial-intelligence/" },
      { text: "dfs.ny.gov — Industry Letter Oct 2024", url: "https://www.dfs.ny.gov/industry-guidance/industry-letters/il20241016-cyber-risks-ai-and-strategies-combat-related-risks" },
    ],
  },
  {
    label: "EU — AI Act and DORA",
    desc: "EU-level regulation for AI in credit decisioning and ICT third-party risk.",
    urls: [
      { text: "eur-lex.europa.eu — Regulation 2024/1689", url: "https://eur-lex.europa.eu/eli/reg/2024/1689/oj" },
      { text: "eur-lex.europa.eu — Regulation 2022/2554", url: "https://eur-lex.europa.eu/eli/reg/2022/2554/oj" },
    ],
  },
  {
    label: "International — FSB, BCBS, EBA, ECB",
    desc: "Cross-border supervisory direction on AI and model risk.",
    urls: [
      { text: "fsb.org — Financial Stability Implications of AI", url: "https://www.fsb.org/2024/11/the-financial-stability-implications-of-artificial-intelligence/" },
      { text: "bis.org — BCBS Newsletter on AI/ML", url: "https://www.bis.org/publ/bcbs_nl27.htm" },
      { text: "eba.europa.eu — ML for IRB follow-up", url: "https://www.eba.europa.eu/publications-and-media/press-releases/eba-publishes-follow-report-use-machine-learning-internal" },
