      { text: "Greg Baer (CEO, Bank Policy Institute)", url: "https://bpi.com/people/greg-baer/" },
      { text: "Alexandra Mousavizadeh (Evident Insights)", url: "https://www.linkedin.com/in/alexandra-mousavizadeh/" },
      { text: "Jón Daníelsson (LSE Systemic Risk Centre)", url: "https://www.systemicrisk.ac.uk/people/jon-danielsson" },
    ],
  },
  {
    label: "Publications",
    desc: "Trade press and specialist publications tracking AI in banking.",
    urls: [
      { text: "risk.net", url: "https://www.risk.net" },
      { text: "americanbanker.com", url: "https://www.americanbanker.com" },
      { text: "bankingdive.com", url: "https://www.bankingdive.com" },
      { text: "centralbanking.com", url: "https://www.centralbanking.com" },
      { text: "Evident AI Banking Brief", url: "https://evidentinsights.com/bankingbrief/" },
    ],
  },
  {
    label: "Newsletters",
    desc: "Substacks covering bank-fintech and AI policy plumbing.",
    urls: [
      { text: "Fintech Business Weekly — Jason Mikula", url: "https://fintechbusinessweekly.substack.com" },
      { text: "Fintech Takes — Alex Johnson", url: "https://newsletter.fintechtakes.com" },
    ],
  },
];
---

<ReferenceArticle
  variant="banking"
  tier="Industry · Banking"
  h1="AI in banking."
  standfirst="SR 11-7 is legacy. SR 26-2 is current. The governance architecture carried through; the language is updated for LLMs. Plus PRA SS1/23, EU AI Act, DORA, and the CFPB layer on top."
  intro={intro}
  verifyTitle="The primary frameworks."
  steps={steps}
  sources={sources}
  newsletterHook="Fed, OCC, PRA, ECB supervisory announcements on AI as they land; how banks are extending SR 26-2 doctrine to LLMs in practice; and which credit-scoring applications are drawing AI Act scrutiny."
/>
