<NarrowAngle
  variant="model-drift"
  umbrellaHref="/synthetic.html"
  umbrellaLabel="Monitoring angle"
  eyebrow="For Head of AI, model governance"
  h1Before="A vendor pushes a model update."
  h1Em="You notice before a customer does."
