---
import ReferenceArticle from "@/components/ReferenceArticle.astro";

const intro = [
  "An adverse decision, in the US insurance regulatory sense, is any decision that results in denial, cancellation, non-renewal, adverse underwriting, or rating up — whether or not an AI System informed the decision. Regulators including NY DFS and the NAIC expect that when an AI System contributes to an adverse decision, the insurer can explain the contribution.",
  "The statutory language across these frameworks is specific. This page quotes the primary texts so the explanation you produce can be anchored against them.",
];

const steps = [
  {
    label: "One, NY DFS — the statutory standard.",
    body: "<a href='https://www.dfs.ny.gov/industry-guidance/circular-letters/cl2024-07' target='_blank' rel='noopener'>Circular Letter No. 7 of 2024</a> states that AI System use must rest on a clear, empirical, statistically significant, rational, and not-unfairly-discriminatory relationship between variables used and the insured risk. That sentence is the bar for the underlying analysis."
  },
  {
    label: "Two, NAIC — AI-informed adverse decisions.",
    body: "The <a href='https://content.naic.org/sites/default/files/inline-files/2023-12-4%20Model%20Bulletin_Adopted_0.pdf' target='_blank' rel='noopener'>NAIC Model Bulletin</a> requires documentation of AI System use in any consumer-facing decision and specifies governance, testing, and third-party oversight. Adverse-decision documentation is a subset."
  },
  {
    label: "Three, Colorado — the quantitative test.",
    body: "<a href='https://leg.colorado.gov/bills/sb21-169' target='_blank' rel='noopener'>Colorado SB21-169</a> and the implementing regulation (3 CCR 702-10) specify a quantitative methodology for life insurers to demonstrate that external consumer data and algorithms do not produce unfairly discriminatory outcomes. The <a href='https://doi.colorado.gov/for-consumers/sb21-169-protecting-consumers-from-unfair-discrimination-in-insurance-practices' target='_blank' rel='noopener'>Colorado DOI page</a> tracks filings."
  },
  {
    label: "Four, EU AI Act — Article 86 right to explanation.",
    body: "The <a href='https://eur-lex.europa.eu/eli/reg/2024/1689/oj' target='_blank' rel='noopener'>AI Act (Regulation 2024/1689)</a>, Article 86, grants affected persons a right to obtain from the deployer meaningful explanations of the role of an AI System in a decision that affects them. For high-risk insurance AI (Annex III), this is a concrete operational obligation."
  },
  {
    label: "Five, what the explanation has to show.",
    body: "The common elements across the four frameworks: the variables used, the weights or influence attributed to each, the data sources (including ECDIS), the statistical-significance basis, the protected-class impact check, and the human-review step (if any). Each framework names the elements in its own language; the operational artifact is substantially overlapping."
  },
];

const sources = [
  {
    label: "US — NY DFS",
    desc: "Circular Letter No. 7 of 2024. The statutory-standard language is in the body text.",
    urls: [
      { text: "dfs.ny.gov — CL 2024-07", url: "https://www.dfs.ny.gov/industry-guidance/circular-letters/cl2024-07" },
    ],
  },
  {
    label: "US — NAIC",
    desc: "Model Bulletin on the Use of AI Systems by Insurers.",
    urls: [
      { text: "Model Bulletin (PDF)", url: "https://content.naic.org/sites/default/files/inline-files/2023-12-4%20Model%20Bulletin_Adopted_0.pdf" },
    ],
  },
  {
    label: "US — Colorado",
    desc: "SB21-169 enacted text and Division of Insurance implementing-regulation resources.",
    urls: [
      { text: "leg.colorado.gov — SB21-169", url: "https://leg.colorado.gov/bills/sb21-169" },
      { text: "doi.colorado.gov — SB21-169 page", url: "https://doi.colorado.gov/for-consumers/sb21-169-protecting-consumers-from-unfair-discrimination-in-insurance-practices" },
    ],
  },
  {
    label: "EU — AI Act",
    desc: "Regulation (EU) 2024/1689. See Articles 11 (technical documentation), 14 (human oversight), and 86 (right to explanation).",
    urls: [
      { text: "eur-lex.europa.eu — Regulation 2024/1689", url: "https://eur-lex.europa.eu/eli/reg/2024/1689/oj" },
    ],
  },
];
---

<ReferenceArticle
  variant="adverse-decision-trail"
  tier="Topic 12 · Compliance"
  h1="Explain every adverse AI decision, statutorily."
  standfirst="The legal tests across NY DFS, NAIC, Colorado, and the EU AI Act. Quoted from source."
  intro={intro}
  verifyTitle="What the primary texts require."
  steps={steps}
  sources={sources}
  newsletterHook="How examinations are actually treating adverse-decision explanations, which formats insurers are settling on, and the revisions coming through Article 86 implementing acts."
/>
