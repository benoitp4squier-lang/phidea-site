---
import ReferenceArticle from "@/components/ReferenceArticle.astro";

const intro = [
  "Generative AI in legal practice has moved faster than the professional-responsibility frameworks. Bar associations are publishing AI-specific guidance; state and federal courts increasingly require disclosure of AI use in filings.",
  "The underlying Model Rules — competence, confidentiality, supervision, candor — apply directly. What is new is how they are being interpreted, and where the duty to supervise an AI tool lands. This page catalogues the primary texts.",
];

const steps = [
  {
    label: "ABA — Formal Opinion 512 (July 2024).",
    body: "The American Bar Association's Formal Opinion 512 on Generative AI Tools applies Model Rules 1.1 (competence), 1.6 (confidentiality), 1.5 (fees), 3.3 (candor to the tribunal), and 5.1/5.3 (supervision) to generative AI use in legal practice. The <a href='https://www.americanbar.org/groups/professional_responsibility/publications/ethics-opinions/' target='_blank' rel='noopener'>ABA Ethics Opinions page</a> hosts the opinion."
  },
  {
    label: "US — state bar guidance.",
    body: "California (State Bar Practical Guidance on Use of Generative AI), New York (NYSBA Task Force on AI), Florida (Ethics Opinion 24-1), DC, and others have published state-specific guidance that interprets the Model Rules in light of generative AI."
  },
  {
    label: "US — federal and state court standing orders.",
    body: "A growing number of US federal and state judges have issued standing orders requiring disclosure or certification of AI use in filings, following the Mata v. Avianca incident (2023) where fabricated case citations appeared in a court submission."
  },
  {
    label: "EU — AI Act (Regulation 2024/1689).",
    body: "Does not name the legal profession as a single high-risk category, but Annex III classifies certain AI uses in the administration of justice as high-risk. Law firms using such AI systems may fall under those obligations depending on deployment."
  },
  {
    label: "UK — SRA and Law Society guidance.",
    body: "The Solicitors Regulation Authority and the Law Society of England and Wales have published guidance on generative AI, covering duties of competence, confidentiality, and supervision under the SRA Code of Conduct."
  },
  {
    label: "GDPR and client data.",
    body: "Client data sent to a third-party AI provider raises processing and cross-border transfer questions under <a href='https://eur-lex.europa.eu/eli/reg/2016/679/oj' target='_blank' rel='noopener'>GDPR (Regulation 2016/679)</a>. The applicable legal basis, data processor contract, and international transfer mechanism all need to be addressed."
  },
];

const sources = [
  {
    label: "US — ABA",
    desc: "American Bar Association Formal Opinion 512 on Generative AI Tools.",
    urls: [
      { text: "americanbar.org — Ethics Opinions", url: "https://www.americanbar.org/groups/professional_responsibility/publications/ethics-opinions/" },
    ],
  },
  {
    label: "US — State bars",
    desc: "California, New York, Florida, DC and others have state-specific generative-AI guidance.",
    urls: [
      { text: "calbar.ca.gov — practical guidance", url: "https://www.calbar.ca.gov/Portals/0/documents/ethics/Generative-AI-Practical-Guidance.pdf" },
      { text: "nysba.org — Task Force on AI", url: "https://nysba.org/task-force-artificial-intelligence/" },
    ],
  },
  {
    label: "EU — AI Act",
    desc: "Regulation (EU) 2024/1689. Annex III covers certain administration-of-justice AI uses.",
    urls: [
      { text: "eur-lex.europa.eu — Regulation 2024/1689", url: "https://eur-lex.europa.eu/eli/reg/2024/1689/oj" },
    ],
  },
  {
    label: "UK — SRA / Law Society",
    desc: "Regulator and professional-body guidance on generative AI in legal practice.",
    urls: [
      { text: "sra.org.uk — AI guidance", url: "https://www.sra.org.uk/solicitors/resources/use-of-artificial-intelligence/" },
      { text: "lawsociety.org.uk — GenAI guidance", url: "https://www.lawsociety.org.uk/topics/ai-and-lawtech/generative-ai-the-essentials" },
    ],
  },
  {
    label: "EU — GDPR",
    desc: "Regulation (EU) 2016/679. Processing, data-processor contracts, and international transfer rules for client data in AI tools.",
    urls: [
      { text: "eur-lex.europa.eu — Regulation 2016/679", url: "https://eur-lex.europa.eu/eli/reg/2016/679/oj" },
    ],
  },
];
---

<ReferenceArticle
  variant="legal"
  tier="Industry · Legal"
  h1="AI in legal practice."
  standfirst="The professional-responsibility rules predate AI; the interpretation is new. ABA Opinion 512 plus state bar guidance plus a growing stack of court orders."
  intro={intro}
  verifyTitle="The primary frameworks."
  steps={steps}
  sources={sources}
  newsletterHook="New state bar opinions and court standing orders as they land, SRA and Law Society updates in the UK, and how firms are structuring supervision of AI-assisted work product."
/>
