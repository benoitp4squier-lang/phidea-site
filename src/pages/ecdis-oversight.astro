---
import ReferenceArticle from "@/components/ReferenceArticle.astro";

const intro = [
  "External Consumer Data and Information Sources — ECDIS — is a term defined in NY DFS Circular Letter No. 7 of 2024. It refers to data or information sources used by an insurer or its AI Systems in underwriting, pricing, marketing, or claims that originate from a third party and were not supplied directly by the consumer.",
  "The concept has direct analogues in the NAIC Model Bulletin (third-party AI and data systems) and in the EU DORA framework (ICT third-party register). Each has primary text; the definitions do not identically overlap.",
];

const steps = [
  {
    label: "One, NY DFS ECDIS definition.",
    body: "<a href='https://www.dfs.ny.gov/industry-guidance/circular-letters/cl2024-07' target='_blank' rel='noopener'>Circular Letter No. 7 of 2024</a> defines ECDIS and requires that insurers maintain governance over them, disclose material elements to consumers, and demonstrate the absence of unfair discrimination arising from their use."
  },
  {
    label: "Two, NAIC — third-party data and AI.",
    body: "The <a href='https://content.naic.org/sites/default/files/inline-files/2023-12-4%20Model%20Bulletin_Adopted_0.pdf' target='_blank' rel='noopener'>NAIC Model Bulletin</a> addresses third-party AI Systems and third-party data used in AI Systems, with similar oversight expectations. It does not use the term ECDIS; the operational concept overlaps."
  },
  {
    label: "Three, EU DORA — ICT third-party register.",
    body: "<a href='https://eur-lex.europa.eu/eli/reg/2022/2554/oj' target='_blank' rel='noopener'>Regulation 2022/2554</a> (DORA) requires insurers as financial entities to maintain a Register of Information on ICT services provided by third parties. The European Supervisory Authorities have published <a href='https://www.eiopa.europa.eu/browse/regulation-and-policy/digital-operational-resilience-act-dora_en' target='_blank' rel='noopener'>technical standards</a> specifying the register's structure."
  },
  {
    label: "Four, how the registers overlap.",
    body: "A single register that satisfies ECDIS under NY DFS and the Register of Information under DORA is achievable: both require identification of the provider, the service, the contract, and the criticality of the service. The ECDIS-specific layer on top is the consumer disclosure obligation."
  },
];

const sources = [
  {
    label: "US — NY DFS",
    desc: "Circular Letter No. 7 of 2024, defining ECDIS and the governance and disclosure obligations.",
    urls: [
      { text: "dfs.ny.gov — CL 2024-07", url: "https://www.dfs.ny.gov/industry-guidance/circular-letters/cl2024-07" },
    ],
  },
  {
    label: "US — NAIC",
    desc: "Model Bulletin on the Use of AI Systems by Insurers, third-party sections.",
    urls: [
      { text: "Model Bulletin (PDF)", url: "https://content.naic.org/sites/default/files/inline-files/2023-12-4%20Model%20Bulletin_Adopted_0.pdf" },
    ],
  },
  {
    label: "EU — DORA",
    desc: "Regulation 2022/2554 and EIOPA technical standards on the Register of Information.",
    urls: [
      { text: "eur-lex.europa.eu — Regulation 2022/2554", url: "https://eur-lex.europa.eu/eli/reg/2022/2554/oj" },
      { text: "eiopa.europa.eu — DORA", url: "https://www.eiopa.europa.eu/browse/regulation-and-policy/digital-operational-resilience-act-dora_en" },
    ],
  },
];
---

<ReferenceArticle
  variant="ecdis-oversight"
  tier="Topic 13 · Compliance"
  h1="Track every third-party data source your models touch."
  standfirst="ECDIS is a defined term. NY DFS wrote the definition. Related registers exist in NAIC and DORA."
  intro={intro}
  verifyTitle="What the primary texts require."
  steps={steps}
  sources={sources}
  newsletterHook="ECDIS-related findings from examinations, evolving EIOPA technical standards under DORA, and the specific third-party data sources that are drawing regulator attention."
/>
