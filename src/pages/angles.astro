---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";

const navLinks = [
  { href: "index.html", label: "Flagship" },
  { href: "#angles", label: "Supporting pages" },
  { href: "#how", label: "How to use" },
];
const navCta = { href: "mailto:benoit@phidea.fr", label: "Email Benoit" };
---

<Layout variant="angles-index" noIndex>
  <Nav variant="angles-index" links={navLinks} cta={navCta} />

  <header class="hero">
    <div class="wrap">
      <span class="eyebrow">Internal · site map</span>
      <h1>One flagship. <em>Five supporting pages.</em></h1>
      <p class="lead">
        The site tells one story: Phidea is the AI governance layer for
        insurers. The flagship carries the umbrella pitch. Five supporting
        pages exist for specific buyers — distribution, monitoring,
        governance, the free scorecard, the newsletter. Developer-tools
        was retired because it wasn't the moat.
      </p>
      <div class="cta-row">
        <a href="index.html" class="btn btn-primary">See the flagship</a>
        <a href="#angles" class="btn btn-ghost">See the supporting pages</a>
      </div>
    </div>
  </header>

  <section id="angles">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">Live pages</div>
        <h2>The consolidated set.</h2>
        <p class="lead">
          All pages share the design system but differ on buyer, proof
          point, and CTA. Every form submission carries a
          <code>variant</code> hidden field and PostHog tags every event
          with the same id, so CRM and analytics agree on attribution.
        </p>
      </div>

      <div class="angle-grid">

        <a class="angle-card" href="index.html">
          <div class="tag">Flagship · Observability</div>
          <h3>Ship AI in insurance. Know the moment it drifts.</h3>
          <p>
            The main pitch. Monitoring, synthetic buyers, live regulatory
            scans, evidence ledger. For Heads of AI, CTOs, and AI-ops
            leads at carriers. CTA: Request a demo.
          </p>
          <div class="url">phidea.eu/</div>
        </a>

        <a class="angle-card" href="distribution.html">
          <div class="tag">Distribution · CMO / Digital</div>
          <h3>Your products, described in ChatGPT. By whom?</h3>
          <p>
            Tier 1 framing. Share of answer across ChatGPT, Claude, Gemini,
            Perplexity. Ship a governed AI app of your own. For Heads of
            Distribution, Digital, CMO. CTA: Get a scorecard.
          </p>
          <div class="url">phidea.eu/distribution.html</div>
        </a>

        <a class="angle-card" href="evidence.html">
          <div class="tag">Governance · Compliance persona</div>
          <h3>Your AIS Program on paper. And the one in production.</h3>
          <p>
            Tier 3 framing. ECDIS log, adverse-decision trail, NAIC / NY DFS
            / Colorado / EU AI Act / DORA mapped bundles. For Heads of
            Compliance, Legal, Risk. CTA: See a sample bundle.
          </p>
          <div class="url">phidea.eu/evidence.html</div>
        </a>

        <a class="angle-card" href="synthetic.html">
          <div class="tag">Synthetic · AI-ops persona</div>
          <h3>Let AI test your AI, 24/7.</h3>
          <p>
            The continuous red-teaming cut. For Heads of AI and QA who
            worry about drift and launch-day regressions. CTA: See it
            probing.
          </p>
          <div class="url">phidea.eu/synthetic.html</div>
        </a>

        <a class="angle-card" href="presence-test.html">
          <div class="tag">Lead magnet · Free tool</div>
          <h3>Test your AI presence.</h3>
          <p>
            Top-of-funnel diagnostic. Free scorecard across ChatGPT,
            Claude, Gemini, Perplexity. Converts curiosity into qualified
            leads. CTA: Run the test.
          </p>
          <div class="url">phidea.eu/presence-test.html</div>
        </a>

        <a class="angle-card" href="newsletter.html">
          <div class="tag">Audience · Newsletter</div>
          <h3>AI in insurance, weekly.</h3>
          <p>
            Lowest-commitment CTA. Builds the audience you eventually
            sell to. Longest-horizon wedge. CTA: Subscribe.
          </p>
          <div class="url">phidea.eu/newsletter.html</div>
        </a>

        <div class="angle-card" style="opacity: 0.55; cursor: default; border-style: dashed;">
          <div class="tag">Retired</div>
          <h3>Developers</h3>
          <p>
            Developers framed Phidea as dev tooling (we are not — the MCP
            and SDKs are inputs, not the moat). URL now redirects to the
            flagship.
          </p>
          <div class="url">phidea.eu/developers.html → /</div>
        </div>

      </div>
    </div>
  </section>

  <section id="narrow" style="padding-top: 16px;">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">Narrow-hook pages · 18 under test</div>
        <h2>One hook per page. One ad creative per page.</h2>
        <p class="lead">
          Each narrow page hosts a single value prop from a single tier, targeted at a single persona, with its own <code>variant</code> tag for CRM attribution. Point paid social, outbound copy, and specific LinkedIn campaigns at the narrow URLs. Let the flagship absorb organic.
        </p>
      </div>

      <div class="narrow-grid">
        <div class="narrow-tier">
          <div class="narrow-tier-label">Tier 1 · Growth / distribution</div>
          <ul class="narrow-list">
            <li><a href="/ai-visibility.html">Findable in ChatGPT</a> <span>CMO · distribution</span></li>
            <li><a href="/competitor-share.html">Competitor cited instead</a> <span>CMO · Head of Digital</span></li>
            <li><a href="/custom-gpt.html">A Custom GPT compliance signs</a> <span>Platform · digital</span></li>
            <li><a href="/ai-channel.html">AI as a distribution channel</a> <span>Head of Distribution</span></li>
            <li><a href="/ai-attribution.html">AI session to bind attribution</a> <span>Growth · revops</span></li>
          </ul>
        </div>
        <div class="narrow-tier">
          <div class="narrow-tier-label">Tier 2 · AI-ops / monitoring</div>
          <ul class="narrow-list">
            <li><a href="/ai-monitoring.html">Observability in production</a> <span>Head of AI · AI-ops</span></li>
            <li><a href="/model-drift.html">Drift between vendor updates</a> <span>Head of AI · model governance</span></li>
            <li><a href="/hallucination-guardrail.html">Block hallucinations before delivery</a> <span>AI-ops · product</span></li>
            <li><a href="/audit-bundle.html">Regulator bundle in one click</a> <span>Compliance · AI-ops</span></li>
          </ul>
        </div>
        <div class="narrow-tier">
          <div class="narrow-tier-label">Tier 3 · Compliance / governance</div>
          <ul class="narrow-list">
            <li><a href="/regulator-mapping.html">Six frameworks, one mapping</a> <span>Compliance · reg affairs</span></li>
            <li><a href="/ais-program.html">AIS Program live inventory</a> <span>Compliance · risk</span></li>
            <li><a href="/adverse-decision-trail.html">Adverse-decision explanations</a> <span>Compliance · legal</span></li>
            <li><a href="/ecdis-oversight.html">ECDIS oversight</a> <span>Compliance · vendor risk</span></li>
            <li><a href="/bias-testing.html">Protected-class testing</a> <span>Compliance · actuarial</span></li>
          </ul>
        </div>
        <div class="narrow-tier">
          <div class="narrow-tier-label">Tier 4 · Actuarial / model risk</div>
          <ul class="narrow-list">
            <li><a href="/mrm-llms.html">MRM extended to LLMs</a> <span>Model risk · actuarial</span></li>
            <li><a href="/predictive-monitoring.html">Rate adequacy monitored live</a> <span>Pricing · reserving</span></li>
            <li><a href="/augmented-underwriting.html">UW policy-as-code</a> <span>Chief UW · UW ops</span></li>
            <li><a href="/portfolio-drift.html">Portfolio drift vs appetite</a> <span>Portfolio · CRO</span></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="how">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">How to use</div>
        <h2>What to point at each page.</h2>
        <p class="lead">
          Each page earns traffic from a different place. Keep the
          mapping tight so CRM attribution and PostHog funnels stay
          readable.
        </p>
      </div>

      <table class="why-table">
        <thead>
          <tr><th>Page</th><th>Traffic source</th><th>Primary KPI</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>Flagship</strong></td>
            <td class="w">Direct outbound, LinkedIn ads to Heads of AI / CTOs at carriers</td>
            <td><strong>Demo request</strong></td>
          </tr>
          <tr>
            <td><strong>Distribution</strong></td>
            <td class="w">CMO / Head of Digital / Distribution at carriers, LinkedIn ads, insurtech social</td>
            <td><strong>Scorecard signup</strong></td>
          </tr>
          <tr>
            <td><strong>Governance (evidence)</strong></td>
            <td class="w">Compliance / legal communities, regulator events, long-tail SEO on bulletin names</td>
            <td><strong>Sample bundle request</strong></td>
          </tr>
          <tr>
            <td><strong>Synthetic</strong></td>
            <td class="w">AI-ops Slack/Discords, QA conferences, drift/red-team content</td>
            <td><strong>Demo request</strong></td>
          </tr>
          <tr>
            <td><strong>Presence Test</strong></td>
            <td class="w">Cold ads, founder social, press, SEO on "ChatGPT for insurance"</td>
            <td><strong>Scorecard signup (email)</strong></td>
          </tr>
          <tr>
            <td><strong>Newsletter</strong></td>
            <td class="w">Everyone else. Content flywheel, referrals, organic.</td>
            <td><strong>Email subscription</strong></td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .narrow-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-top: 16px;
  }
  .narrow-tier {
    padding: 20px 24px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--soft);
  }
  .narrow-tier-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
  }
  .narrow-list { list-style: none; padding: 0; margin: 0; }
  .narrow-list li {
    padding: 8px 0;
    border-bottom: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: baseline;
  }
  .narrow-list li:last-child { border-bottom: none; }
  .narrow-list li a {
    color: var(--ink);
    text-decoration: none;
    font-weight: 500;
    font-size: 15px;
  }
  .narrow-list li a:hover { color: var(--accent); }
  .narrow-list li span {
    font-size: 12px;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    white-space: nowrap;
  }
  @media (max-width: 720px) {
    .narrow-grid { grid-template-columns: 1fr; gap: 20px; }
    .narrow-list li { flex-direction: column; gap: 4px; align-items: flex-start; }
  }
</style>
