---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import type { VariantId } from "@/lib/variants";

interface VerifyStep {
  label: string;
  body: string;
}
interface SourceUrl {
  text: string;
  url: string;
}
interface SourceRow {
  label: string;
  desc: string;
  urls: SourceUrl[];
}
interface Props {
  variant: VariantId;
  tier: string;
  h1: string;
  standfirst: string;
  intro: string[];
  verifyTitle: string;
  steps: VerifyStep[];
  limitsTitle?: string;
  limitsBody?: string;
  sources: SourceRow[];
  newsletterHook: string;
}

const { variant, tier, h1, standfirst, intro, verifyTitle, steps, limitsTitle, limitsBody, sources, newsletterHook } = Astro.props;

// Rough read-time: 250 wpm on prose; approximate based on content heft
const wordCount = intro.join(" ").split(/\s+/).length
  + steps.reduce((n, s) => n + s.label.split(/\s+/).length + s.body.split(/\s+/).length, 0)
  + (limitsBody ? limitsBody.split(/\s+/).length : 0);
const readMin = Math.max(2, Math.round(wordCount / 240));

// Letter badges for source providers (first 2 letters of label)
const initials = (s: string) => {
  const clean = s.replace(/^(US|EU|UK)\s*[-—]\s*/i, "").trim();
  const parts = clean.split(/\s+/);
  if (parts.length >= 2) return (parts[0][0] + parts[1][0]).toUpperCase();
  return clean.slice(0, 2).toUpperCase();
};

// Pick a deterministic-looking accent shade per source, from a small palette
const swatchFor = (s: string) => {
  const palette = ["#f04e36", "#1f6feb", "#8957e5", "#2da44e", "#bf8700", "#0d4f86", "#cf2b4f"];
  let h = 0;
  for (const ch of s) h = (h * 31 + ch.charCodeAt(0)) >>> 0;
  return palette[h % palette.length];
};
---

<Layout variant={variant}>
  <Nav
    variant={variant}
    links={[
      { href: "/", label: "Phidea" },
      { href: "/#archive", label: "Topics" },
      { href: "/#subscribe", label: "Subscribe" },
    ]}
    cta={{ href: "#subscribe", label: "Subscribe →" }}
  />

  <article class="article">
    <header class="article-head">
      <div class="wrap wrap-article">
        <div class="article-meta">
          <span>{tier}</span>
          <span class="dot-sep"></span>
          <span>Reference</span>
          <span class="dot-sep"></span>
          <span>{readMin} min read</span>
        </div>
        <h1>{h1}</h1>
        <p class="standfirst">{standfirst}</p>

        <nav class="on-this-page" aria-label="On this page">
          <span class="otp-label">On this page</span>
          <a href="#overview">Overview</a>
          <a href="#checks">Checks</a>
          {limitsTitle && <a href="#limits">Limits</a>}
          <a href="#sources">Sources</a>
        </nav>
      </div>
    </header>

    <section id="overview" class="article-body">
      <div class="wrap wrap-article">
        {intro.map((p) => <p set:html={p}></p>)}
      </div>
    </section>

    <section id="checks" class="checks">
      <div class="wrap wrap-article">
        <div class="section-rule">
          <span class="section-rule-label">Checks</span>
        </div>
        <h2>{verifyTitle}</h2>
        <ol class="step-cards">
          {steps.map((s, i) => (
            <li class="step-card">
              <div class="step-num">{String(i + 1).padStart(2, "0")}</div>
              <div class="step-content">
                <h3 class="step-title">{s.label}</h3>
                <p class="step-body" set:html={s.body}></p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    {limitsTitle && (
      <section id="limits" class="limits">
        <div class="wrap wrap-article">
          <div class="section-rule">
            <span class="section-rule-label">Limits</span>
          </div>
          <h2>{limitsTitle}</h2>
          <p class="limits-body" set:html={limitsBody}></p>
        </div>
      </section>
    )}

    <section id="sources" class="sources-section">
      <div class="wrap wrap-article">
        <div class="section-rule">
          <span class="section-rule-label">Sources</span>
        </div>
        <h2>Primary sources and references.</h2>
        <ul class="source-cards">
          {sources.map((src) => (
            <li class="source-card">
              <div class="source-card-head">
                <span class="source-badge" style={`--swatch: ${swatchFor(src.label)}`}>{initials(src.label)}</span>
                <div>
                  <div class="source-label">{src.label}</div>
                  <p class="source-desc">{src.desc}</p>
                </div>
              </div>
              <ul class="source-urls">
                {src.urls.map((u) => (
                  <li>
                    <a href={u.url} target="_blank" rel="noopener">
                      <span class="ext-arrow">↗</span>
                      <span class="url-text">{u.text}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          ))}
        </ul>

        <p class="meta-note">
          This page is a reference. Observations and comparisons that cannot be sourced are in the weekly newsletter, where they belong.
        </p>
      </div>
    </section>

    <section id="subscribe" class="subscribe-strip">
      <div class="wrap wrap-article">
        <div class="section-label">Phidea Weekly</div>
        <h3>The part this page does not cover.</h3>
        <p>{newsletterHook}</p>
        <form action="https://buttondown.email/api/emails/embed-subscribe/phidea" method="POST" class="signup">
          <input type="hidden" name="tag" value={variant} />
          <input type="email" name="email" placeholder="Your email" required />
          <button type="submit">Subscribe →</button>
        </form>
        <p class="signup-small">One email per week. Unsubscribe in one click.</p>
      </div>
    </section>
  </article>

  <Footer />
</Layout>

<style>
  .wrap-article { max-width: 720px; padding-left: 24px; padding-right: 24px; margin: 0 auto; }

  /* Hero */
  .article-head { padding: 64px 0 28px; }
  .article-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.04em;
    margin-bottom: 28px;
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
  }
  .dot-sep {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--muted);
    opacity: 0.5;
  }
  .article-head h1 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 46px;
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0 0 20px;
    font-weight: 500;
    color: var(--ink);
  }
  .standfirst {
    font-size: 21px;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0 0 36px;
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    font-weight: 400;
  }

  /* On this page mini-nav */
  .on-this-page {
    display: flex;
    align-items: baseline;
    gap: 18px;
    padding: 14px 18px;
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: 10px;
    flex-wrap: wrap;
    font-size: 13px;
  }
  .otp-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .on-this-page a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px dashed var(--line);
    padding-bottom: 1px;
  }
  .on-this-page a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* Body prose */
  .article-body { padding: 40px 0 16px; }
  .article-body p {
    font-size: 18px;
    line-height: 1.68;
    color: var(--ink-2);
    margin: 0 0 22px;
    font-family: 'Fraunces', Georgia, serif;
  }
  .article-body p a,
  .step-body a,
  .limits-body a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid rgba(240, 78, 54, 0.3);
  }
  .article-body p a:hover,
  .step-body a:hover,
  .limits-body a:hover { border-bottom-color: var(--accent); }

  .article-body code,
  .step-body code,
  .limits-body code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
    background: var(--soft);
    padding: 2px 7px;
    border-radius: 5px;
    color: var(--ink);
    border: 1px solid var(--line);
  }

  /* Section rule (pre-heading marker) */
  .section-rule {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 48px 0 20px;
  }
  .section-rule::before,
  .section-rule::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--line);
  }
  .section-rule-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  /* Section headings */
  .checks h2, .limits h2, .sources-section h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 28px;
    line-height: 1.2;
    font-weight: 500;
    margin: 0 0 28px;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  /* Checks: numbered step cards */
  .checks { padding: 8px 0 32px; }
  .step-cards { list-style: none; padding: 0; margin: 0; }
  .step-card {
    display: grid;
    grid-template-columns: 64px 1fr;
    column-gap: 18px;
    padding: 22px 0;
    border-bottom: 1px solid var(--line);
  }
  .step-card:first-child { padding-top: 4px; }
  .step-card:last-child { border-bottom: none; padding-bottom: 8px; }
  .step-num {
    font-family: 'JetBrains Mono', monospace;
    font-size: 30px;
    font-weight: 500;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -0.01em;
  }
  .step-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 20px;
    line-height: 1.3;
    font-weight: 600;
    margin: 2px 0 10px;
    color: var(--ink);
  }
  .step-body {
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0;
    font-family: 'Fraunces', Georgia, serif;
  }

  /* Limits */
  .limits { padding: 8px 0 32px; }
  .limits-body {
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink-2);
    margin: 0;
    font-family: 'Fraunces', Georgia, serif;
    padding: 20px 24px;
    background: var(--soft);
    border-left: 3px solid var(--accent);
    border-radius: 0 10px 10px 0;
  }

  /* Sources as cards */
  .sources-section { padding: 8px 0 48px; }
  .source-cards { list-style: none; padding: 0; margin: 0 0 32px; }
  .source-card {
    padding: 20px 22px;
    border: 1px solid var(--line);
    border-radius: 12px;
    margin-bottom: 12px;
    background: var(--bg);
    transition: border-color 0.15s ease;
  }
  .source-card:hover { border-color: var(--accent); }
  .source-card-head {
    display: grid;
    grid-template-columns: 44px 1fr;
    column-gap: 14px;
    align-items: start;
    margin-bottom: 14px;
  }
  .source-badge {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--swatch, var(--accent));
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }
  .source-label {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 15px;
    color: var(--ink);
    margin-bottom: 3px;
  }
  .source-desc {
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0;
    font-family: 'Inter', sans-serif;
  }
  .source-urls {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-left: 58px;
  }
  .source-urls li { margin: 0; }
  .source-urls a {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    color: var(--accent);
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12.5px;
    padding: 4px 0;
    word-break: break-word;
  }
  .source-urls a:hover { text-decoration: underline; }
  .ext-arrow {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    flex-shrink: 0;
  }

  .meta-note {
    font-size: 13.5px;
    color: var(--muted);
    font-style: italic;
    line-height: 1.55;
    font-family: 'Inter', sans-serif !important;
    padding: 16px 0 0;
    border-top: 1px solid var(--line);
    margin-top: 16px;
  }

  /* Subscribe */
  .section-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .subscribe-strip {
    padding: 72px 0 96px;
    background: var(--soft);
    border-top: 1px solid var(--line);
  }
  .subscribe-strip h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 30px;
    line-height: 1.2;
    margin: 0 0 14px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .subscribe-strip p {
    font-size: 16px;
    color: var(--ink-2);
    margin: 0 0 24px;
    font-family: 'Inter', sans-serif;
    line-height: 1.55;
    max-width: 560px;
  }
  .signup { display: flex; gap: 10px; max-width: 480px; }
  .signup input[type=email] {
    flex: 1;
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: 10px;
    font-size: 15px;
    font-family: inherit;
    background: var(--bg);
    color: var(--ink);
  }
  .signup input[type=email]:focus {
    outline: none;
    border-color: var(--accent);
  }
  .signup button {
    padding: 14px 22px;
    border: none;
    background: var(--ink);
    color: var(--bg);
    border-radius: 10px;
    font-weight: 500;
    cursor: pointer;
    font-size: 15px;
    font-family: inherit;
    transition: background 0.15s ease;
  }
  .signup button:hover { background: var(--accent); }
  .signup-small {
    font-size: 13px;
    color: var(--muted);
    margin-top: 12px;
    font-family: 'Inter', sans-serif;
  }

  @media (max-width: 720px) {
    .article-head h1 { font-size: 32px; }
    .standfirst { font-size: 18px; }
    .article-body p { font-size: 16.5px; }
    .step-card { grid-template-columns: 44px 1fr; column-gap: 14px; padding: 18px 0; }
    .step-num { font-size: 22px; }
    .step-title { font-size: 17px; }
    .step-body { font-size: 15px; }
    .source-urls { padding-left: 0; margin-top: 4px; }
    .checks h2, .limits h2, .sources-section h2 { font-size: 22px; }
    .subscribe-strip h3 { font-size: 24px; }
    .signup { flex-direction: column; }
  }
</style>
