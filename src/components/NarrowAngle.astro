---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import type { VariantId } from "@/lib/variants";

interface Props {
  variant: VariantId;
  tier: string;
  h1: string;
  lead: string;
  whyTitle: string;
  whyBody: string;
  watchTitle: string;
  watchPoints: string[];
  newsletterPrompt: string;
}

const { variant, tier, h1, lead, whyTitle, whyBody, watchTitle, watchPoints, newsletterPrompt } = Astro.props;
---

<Layout variant={variant}>
  <Nav
    variant={variant}
    links={[
      { href: "/", label: "Phidea" },
      { href: "/angles.html", label: "All angles" },
      { href: "/newsletter.html", label: "Weekly brief" },
    ]}
    cta={{ href: "#subscribe", label: "Subscribe →" }}
  />

  <article class="essay">
    <header class="essay-hero">
      <div class="wrap wrap-narrow">
        <div class="essay-meta">{tier}</div>
        <h1>{h1}</h1>
        <p class="lead">{lead}</p>
      </div>
    </header>

    <section class="essay-body">
      <div class="wrap wrap-narrow">
        <h2>{whyTitle}</h2>
        <p>{whyBody}</p>

        <h2>{watchTitle}</h2>
        <ol class="essay-list">
          {watchPoints.map((p) => <li>{p}</li>)}
        </ol>
      </div>
    </section>

    <section id="subscribe" class="essay-cta">
      <div class="wrap wrap-narrow">
        <div class="essay-meta" style="margin-bottom: 12px;">Phidea Weekly</div>
        <h2>One brief per week. Free.</h2>
        <p>{newsletterPrompt}</p>
        <form action="https://buttondown.email/api/emails/embed-subscribe/phidea" method="POST" class="signup">
          <input type="hidden" name="tag" value={variant} />
          <input type="email" name="email" placeholder="you@carrier.com" required />
          <button type="submit">Subscribe →</button>
        </form>
        <p class="small">One email, Tuesday mornings. Unsubscribe in one click. No sales pitch.</p>
      </div>
    </section>
  </article>

  <Footer />
</Layout>

<style>
  .wrap-narrow { max-width: 680px; padding-left: 24px; padding-right: 24px; margin: 0 auto; }
  .essay-hero { padding: 72px 0 40px; }
  .essay-meta { font-family: 'JetBrains Mono', monospace; font-size: 12px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); margin-bottom: 20px; }
  .essay-hero h1 { font-family: 'Fraunces', Georgia, serif; font-size: 46px; line-height: 1.12; margin: 0 0 24px; font-weight: 500; letter-spacing: -0.01em; }
  .essay-hero .lead { font-size: 20px; line-height: 1.55; color: var(--ink-2); margin: 0; }
  .essay-body { padding: 24px 0 48px; }
  .essay-body h2 { font-family: 'Fraunces', Georgia, serif; font-size: 24px; margin: 40px 0 12px; font-weight: 500; line-height: 1.2; }
  .essay-body p { font-size: 17px; line-height: 1.7; color: var(--ink-2); margin: 0; }
  .essay-list { counter-reset: item; list-style: none; padding: 0; margin: 16px 0 0; }
  .essay-list li {
    counter-increment: item;
    padding: 18px 0 18px 48px;
    border-bottom: 1px solid var(--line);
    position: relative;
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-2);
  }
  .essay-list li::before {
    content: counter(item, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 18px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--accent);
    font-weight: 500;
  }
  .essay-list li:last-child { border-bottom: none; }
  .essay-cta { padding: 72px 0; background: var(--soft); border-top: 1px solid var(--line); }
  .essay-cta h2 { font-family: 'Fraunces', Georgia, serif; font-size: 34px; margin: 0 0 12px; font-weight: 500; }
  .essay-cta p { color: var(--ink-2); font-size: 17px; line-height: 1.55; margin: 0; }
  .essay-cta .signup { display: flex; gap: 10px; margin-top: 24px; max-width: 520px; }
  .essay-cta .signup input[type=email] {
    flex: 1;
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: 10px;
    font-size: 15px;
    font-family: inherit;
  }
  .essay-cta .signup button {
    padding: 14px 24px;
    border: none;
    background: var(--ink);
    color: var(--bg);
    border-radius: 10px;
    font-weight: 500;
    cursor: pointer;
    font-size: 15px;
    font-family: inherit;
  }
  .essay-cta .signup button:hover { background: var(--accent); }
  .essay-cta .small { font-size: 13px; color: var(--muted); margin-top: 12px; }
  @media (max-width: 720px) {
    .essay-hero h1 { font-size: 32px; }
    .essay-hero .lead { font-size: 18px; }
    .essay-cta .signup { flex-direction: column; }
    .essay-cta h2 { font-size: 26px; }
  }
</style>
