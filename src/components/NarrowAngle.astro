---
import Layout from "@/layouts/Layout.astro";
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import type { VariantId } from "@/lib/variants";

interface FAQ { q: string; a: string; }
interface Props {
  variant: VariantId;
  umbrellaHref: string;
  umbrellaLabel: string;
  eyebrow: string;
  h1Before: string;
  h1Em: string;
  h1After?: string;
  lead: string;
  sectionEyebrow: string;
  sectionH2: string;
  sectionBody: string;
  faqs: FAQ[];
  ctaH2: string;
  ctaBody: string;
  ctaButton: string;
}

const { variant, umbrellaHref, umbrellaLabel, eyebrow, h1Before, h1Em, h1After = "", lead, sectionEyebrow, sectionH2, sectionBody, faqs, ctaH2, ctaBody, ctaButton } = Astro.props;
---

<Layout variant={variant}>
  <Nav
    variant={variant}
    links={[
      { href: "/", label: "Flagship" },
      { href: umbrellaHref, label: umbrellaLabel },
      { href: "#faq", label: "FAQ" },
    ]}
    cta={{ href: "#demo", label: "Request a demo →" }}
  />

  <header class="hero">
    <div class="wrap">
      <span class="eyebrow">{eyebrow}</span>
      <h1>{h1Before} <em>{h1Em}</em>{h1After}</h1>
      <p class="lead">{lead}</p>
      <div class="cta-row">
        <a href="#demo" class="btn btn-primary">Request a demo →</a>
        <a href={umbrellaHref} class="btn btn-ghost">{umbrellaLabel}</a>
      </div>
    </div>
  </header>

  <section style="padding: 88px 0;">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">{sectionEyebrow}</div>
        <h2>{sectionH2}</h2>
        <p class="lead">{sectionBody}</p>
      </div>
    </div>
  </section>

  <section id="faq" style="padding: 88px 0; background: var(--soft); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line);">
    <div class="wrap">
      <div class="section-head">
        <div class="section-eyebrow">FAQ</div>
        <h2>Straight answers.</h2>
      </div>
      {faqs.map((faq) => (
        <details>
          <summary>{faq.q}</summary>
          <p>{faq.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section id="demo" style="padding: 88px 0;">
    <div class="wrap">
      <div class="cta-panel" style="text-align: center; max-width: 720px; margin: 0 auto;">
        <h2>{ctaH2}</h2>
        <p>{ctaBody}</p>
        <form action="https://phidea-forms.vercel.app/api/lead" method="POST" style="max-width: 480px; margin: 0 auto; display: flex; flex-direction: column; gap: 12px;">
          <input type="hidden" name="variant" value={variant} />
          <input type="email" name="email" placeholder="work@carrier.com" required style="padding: 14px 16px; border: 1px solid var(--line); border-radius: 10px; font-size: 15px;" />
          <input type="text" name="carrier" placeholder="Carrier name" required style="padding: 14px 16px; border: 1px solid var(--line); border-radius: 10px; font-size: 15px;" />
          <button type="submit" class="btn btn-primary" style="align-self: center;">{ctaButton}</button>
        </form>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
